# ============================================================
# 链客宝 .dockerignore — Docker 构建上下文排除
# ============================================================

# ---- 依赖目录 ----
node_modules/
venv/
venv_new/
backend/venv/
backend/venv_new/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
.pytest_cache/

# ---- 构建产物 ----
dist/
build/
*.db
*.db.bak
backend/data/*.db
backend/data/*.db.bak

# ---- 版本控制 ----
.git/
.gitignore
.gitattributes
.github/

# ---- 环境变量（敏感信息） ----
.env
.env.*
!.env.example
*.pem
*.key
secrets.*

# ---- IDE / 编辑器 ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---- 日志 ----
*.log
logs/

# ---- 文档（无需进入构建上下文） ----
*.md
*.pdf
*.docx

# ---- Docker 相关（避免循环引用） ----
.dockerignore
docker-compose*.yml

# ---- 项目特有 ----
tmp/
coverage/
