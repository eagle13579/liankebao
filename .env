# =============================================================================
# 链客宝 (LianKeBao) — 环境变量配置（生产环境）
# =============================================================================
# 从 .env.example 生成，已切换到 PostgreSQL 生产模式
# 开发环境请使用 .env.dev
# =============================================================================

# =============================================================================
# [基础] Gemini AI API
# =============================================================================
GEMINI_API_KEY=""
APP_URL="http://localhost:8000"
VITE_API_BASE="/lkapi"

# =============================================================================
# [数据库] 切换开关: USE_POSTGRES=1 启用 PostgreSQL，=0 使用 SQLite（默认）
# =============================================================================
USE_POSTGRES=0
# PG_URL=postgresql+psycopg2://chainke:chainke_pg_2026@127.0.0.1:5432/chainke
PG_HOST="127.0.0.1"
PG_PORT="5432"
PG_USER="chainke"
PG_PASSWORD=chainke_pg_2026
PG_DATABASE="chainke"

# =============================================================================
# [支付] 微信支付 — 全部留空，使用 mock 模式
# =============================================================================
WXPAY_MCHID=""
WXPAY_API_V3_KEY=""
WXPAY_CERT_SERIAL_NO=""
WXPAY_CERT_PATH=""
WXPAY_PLATFORM_CERT_PATH=""
WXPAY_NOTIFY_URL=""
WXPAY_REFUND_NOTIFY_URL=""
WXPAY_APPID=""

# 微信支付 V2 兼容环境变量
WEIXIN_APPID=""
MCH_ID=""
API_KEY=""
API_SECRET=""
NOTIFY_URL=""

# 支付模块 WECHAT_ 前缀配置
WECHAT_APPID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""
WECHAT_API_V3_KEY=""
WECHAT_PRIVATE_KEY_PATH=""
WECHAT_CERT_SERIAL_NO=""
WECHAT_NOTIFY_URL=""
WECHAT_REFUND_NOTIFY_URL=""
WECHAT_CERT_PATH=""
WECHAT_KEY_PATH=""
WECHAT_ROOT_CA_PATH=""

# =============================================================================
# [支付] 微信支付 V3 SDK (app/payment/wechat_pay.py) — 全部注释掉，启用前取消注释
# =============================================================================
# 使用说明:
#   1. 在微信支付商户平台完成以下配置:
#      - 账户中心 → 商户信息 → 获取商户号 (MCHID)
#      - 产品中心 → JSAPI支付 → 关联 AppID
#      - 账户中心 → API安全 → 设置 APIv3 密钥
#      - 账户中心 → API安全 → 申请证书 → 下载 apiclient_key.pem
#   2. 取消下方配置项注释，填入实际值
#   3. 设置回调 URL 到商户平台
#   4. 重启服务
#
# 注意: 全部留空则自动使用 Mock 模式，不影响现有功能
#
# WECHAT_APPID=wx1234567890abcdef        # 公众号/小程序 AppID
# WECHAT_MCHID=1230000109                # 微信支付商户号
# WECHAT_API_KEY=                        # APIv2 密钥 (V2 兼容, 可选)
# WECHAT_API_V3_KEY=your_32byte_v3_key   # APIv3 密钥 (32位十六进制字符串)
# WECHAT_CERT_SERIAL=                     # 商户证书序列号 (可自动从证书文件读取)
# WECHAT_CERT_PATH=/path/to/apiclient_key.pem  # 商户私钥证书 PEM 路径
# WECHAT_NOTIFY_URL=https://yourdomain.com/api/payment/wechat/notify  # 支付回调URL
# WECHAT_REFUND_NOTIFY_URL=              # 退款回调URL (可选, 默认使用 NOTIFY_URL)
# WECHAT_PLATFORM_CERT_DIR=/tmp/wechat_certs  # 平台证书缓存目录

# =============================================================================
# [监控] Sentry — 留空关闭
# =============================================================================
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.0"

# =============================================================================
# [通知] 推送配置 — 留空
# =============================================================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# =============================================================================
# [认证] JWT 配置
# =============================================================================
SECRET_KEY="liankebao-dev-secret-key-2026"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# [CORS] 跨域配置
# =============================================================================
CORS_ORIGINS="*"

# =============================================================================
# [AI] DeepSeek + 向量搜索
# =============================================================================
DEEPSEEK_API_KEY=sk-9030fb94757f40afa991995ce89e0f89
USE_VECTOR_SEARCH=1
DB_TYPE=postgres
# DATABASE_URL=  (PostgreSQL 优先使用 PG_* 变量)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true

# =============================================================================
# [PostHog] 用户行为分析 — 设置 API Key 启用
# =============================================================================
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_DEBUG=false
