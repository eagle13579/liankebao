# =============================================================================
# 链客宝 (LianKeBao) — 环境变量配置（本地开发）
# =============================================================================
# 从 .env.example 生成，仅保留必要配置
# =============================================================================

# =============================================================================
# [基础] Gemini AI API
# =============================================================================
GEMINI_API_KEY=""
APP_URL="http://localhost:8000"
VITE_API_BASE="/lkapi"

# =============================================================================
# [数据库] 留空则自动使用 SQLite
# =============================================================================
PG_HOST=""
PG_PORT=""
PG_USER=""
PG_PASSWORD=""
PG_DATABASE=""

# =============================================================================
# [支付] 微信支付 — 全部留空，使用 mock 模式
# =============================================================================
WXPAY_MCHID=""
WXPAY_API_V3_KEY=""
WXPAY_CERT_SERIAL_NO=""
WXPAY_CERT_PATH=""
WXPAY_PLATFORM_CERT_PATH=""
WXPAY_NOTIFY_URL=""
WXPAY_REFUND_NOTIFY_URL=""
WXPAY_APPID=""

# 微信支付 V2 兼容环境变量
WEIXIN_APPID=""
MCH_ID=""
API_KEY=""
API_SECRET=""
NOTIFY_URL=""

# 支付模块 WECHAT_ 前缀配置
WECHAT_APPID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""
WECHAT_API_V3_KEY=""
WECHAT_PRIVATE_KEY_PATH=""
WECHAT_CERT_SERIAL_NO=""
WECHAT_NOTIFY_URL=""
WECHAT_REFUND_NOTIFY_URL=""
WECHAT_CERT_PATH=""
WECHAT_KEY_PATH=""
WECHAT_ROOT_CA_PATH=""

# =============================================================================
# [监控] Sentry — 留空关闭
# =============================================================================
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.0"

# =============================================================================
# [通知] 推送配置 — 留空
# =============================================================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# =============================================================================
# [认证] JWT 配置
# =============================================================================
SECRET_KEY="liankebao-dev-secret-key-2026"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# [CORS] 跨域配置
# =============================================================================
CORS_ORIGINS="*"

# =============================================================================
# [AI] DeepSeek + 向量搜索
# =============================================================================
DEEPSEEK_API_KEY=sk-9030fb94757f40afa991995ce89e0f89
USE_VECTOR_SEARCH=1
