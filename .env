# =============================================================================
# 链客宝 (LianKeBao) — 环境变量配置（生产环境）
# =============================================================================
# 从 .env.example 生成，已切换到 PostgreSQL 生产模式
# 开发环境请使用 .env.dev
# =============================================================================

# =============================================================================
# [基础] Gemini AI API
# =============================================================================
GEMINI_API_KEY=""
APP_URL="http://localhost:8000"
VITE_API_BASE="/lkapi"

# =============================================================================
# [数据库] 留空则自动使用 SQLite
# =============================================================================
PG_HOST="127.0.0.1"
PG_PORT="5432"
PG_USER="chainke"
PG_PASSWORD=chainke_pg_2026
PG_DATABASE="chainke"

# =============================================================================
# [支付] 微信支付 — 全部留空，使用 mock 模式
# =============================================================================
WXPAY_MCHID=""
WXPAY_API_V3_KEY=""
WXPAY_CERT_SERIAL_NO=""
WXPAY_CERT_PATH=""
WXPAY_PLATFORM_CERT_PATH=""
WXPAY_NOTIFY_URL=""
WXPAY_REFUND_NOTIFY_URL=""
WXPAY_APPID=""

# 微信支付 V2 兼容环境变量
WEIXIN_APPID=""
MCH_ID=""
API_KEY=""
API_SECRET=""
NOTIFY_URL=""

# 支付模块 WECHAT_ 前缀配置
WECHAT_APPID=""
WECHAT_MCH_ID=""
WECHAT_API_KEY=""
WECHAT_API_V3_KEY=""
WECHAT_PRIVATE_KEY_PATH=""
WECHAT_CERT_SERIAL_NO=""
WECHAT_NOTIFY_URL=""
WECHAT_REFUND_NOTIFY_URL=""
WECHAT_CERT_PATH=""
WECHAT_KEY_PATH=""
WECHAT_ROOT_CA_PATH=""

# =============================================================================
# [监控] Sentry — 留空关闭
# =============================================================================
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.0"

# =============================================================================
# [通知] 推送配置 — 留空
# =============================================================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# =============================================================================
# [认证] JWT 配置
# =============================================================================
SECRET_KEY="liankebao-dev-secret-key-2026"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# [CORS] 跨域配置
# =============================================================================
CORS_ORIGINS="*"

# =============================================================================
# [AI] DeepSeek + 向量搜索
# =============================================================================
DEEPSEEK_API_KEY=sk-9030fb94757f40afa991995ce89e0f89
USE_VECTOR_SEARCH=1
DB_TYPE=postgres
# DATABASE_URL=  (PostgreSQL 优先使用 PG_* 变量)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true

# =============================================================================
# [PostHog] 用户行为分析 — 设置 API Key 启用
# =============================================================================
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_DEBUG=false
