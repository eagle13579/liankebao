# =============================================================================
# 链客宝 (LianKeBao) — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并根据实际环境修改值
#   cp .env.example .env
# =============================================================================


# =============================================================================
# [基础] Gemini AI API
# =============================================================================
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="***"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_API_BASE: Backend API base URL (e.g., '/lkapi' or 'https://api.example.com/lkapi')
VITE_API_BASE="/lkapi"


# =============================================================================
# [数据库] PostgreSQL 配置（使用 psycopg2 驱动）
# =============================================================================
# 若设置了 PG_HOST + PG_USER + PG_PASSWORD + PG_DATABASE，则使用 PostgreSQL。
# 若未设置任何 PG_* 变量，自动回退到 SQLite (backend/data/chainke.db)。
# 可选依赖: pip install psycopg2-binary
PG_HOST="127.0.0.1"
PG_PORT="5432"
PG_USER="liankebao"
PG_PASSWORD="***"
PG_DATABASE="liankebao"

# SQLite 数据库路径（仅在使用 SQLite 时生效，默认 backend/data/chainke.db）
# SQLITE_PATH=""

# 兼容旧版：DATABASE_URL 仍然可用（MySQL 用），但 PostgreSQL 优先走 PG_* 变量
# DATABASE_URL=""


# =============================================================================
# [支付] 微信支付 (V3)
# =============================================================================
# 商户号
WXPAY_MCHID="***"
# 商户 API v3 密钥（32位，APIv3 密钥，非 APIv2）
WXPAY_API_V3_KEY="***"
# 商户证书序列号（通过 openssl 查看）
WXPAY_CERT_SERIAL_NO="***"
# 商户 API 证书路径（apiclient_key.pem，相对于 backend/ 或绝对路径）
WXPAY_CERT_PATH="certs/apiclient_key.pem"
# 微信支付平台证书路径（下载后存放位置）
WXPAY_PLATFORM_CERT_PATH="certs/platform_cert.pem"
# 微信支付回调通知 URL（需公网可访问）
WXPAY_NOTIFY_URL="https://example.com/lkapi/wechat/pay/notify"
# 退款回调通知 URL
WXPAY_REFUND_NOTIFY_URL="https://example.com/lkapi/wechat/refund/notify"
# 小程序 AppID（与微信支付绑定的 appid）
WXPAY_APPID="wx***"


# =============================================================================
# [监控] Sentry
# =============================================================================
# 从 sentry.io 获取 DSN
SENTRY_DSN="https://***@***.ingest.us.sentry.io/***"
# Sentry 环境标识（development / staging / production）
SENTRY_ENVIRONMENT="development"
# Sentry 采样率（0.0 ~ 1.0，生产环境建议 0.1 ~ 0.5）
SENTRY_TRACES_SAMPLE_RATE="0.1"


# =============================================================================
# [通知] 推送配置
# =============================================================================
# 邮件通知（SMTP）
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="notify@example.com"
SMTP_PASSWORD="***"
SMTP_FROM="链客宝通知 <noreply@example.com>"

# 短信通知（例如阿里云 SMS）
# SMS_ACCESS_KEY_ID="***"
# SMS_ACCESS_KEY_SECRET="***"
# SMS_SIGN_NAME="链客宝"
# SMS_TEMPLATE_CODE="SMS_***"

# 企业微信机器人 Webhook（可选）
# WECHAT_BOT_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=***"


# =============================================================================
# [认证] JWT 配置
# =============================================================================
# JWT 密钥（生产环境请使用足够的随机字符串）
SECRET_KEY="change-this-to-a-random-secret-key"
# JWT 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
# JWT 刷新令牌过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS="7"


# =============================================================================
# [CORS] 跨域配置
# =============================================================================
# 允许的跨域来源（逗号分隔）
# CORS_ORIGINS="https://example.com,https://admin.example.com"
CORS_ORIGINS="*"
