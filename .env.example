# ============================================================
# 链客宝 - 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填写实际值:
#   cp .env.example .env
# ============================================================

# ── 数据库配置 ───────────────────────────────────────────────
# 数据库类型: sqlite (默认) | mysql
DB_TYPE=sqlite

# 数据库连接字符串 (SQLite 或 MySQL)
# SQLite:   sqlite:///data/chainke.db (默认)
# MySQL:    mysql+pymysql://user:password@host:3306/liankebao?charset=utf8mb4
# DATABASE_URL=

# 数字图册独立数据库目录 (默认: /app/data)
# BROCHURE_DB_DIR=/app/data

# SQLAlchemy 日志输出 (true/false)
SQL_ECHO=false

# ── CORS 配置 ────────────────────────────────────────────────
# 允许的跨域源, 逗号分隔, * 表示允许所有
CORS_ORIGINS=*

# ── 服务器配置 ───────────────────────────────────────────────
# 服务端口 (默认 8003)
# PORT=8003

# ── 日志配置 ─────────────────────────────────────────────────
# 日志级别: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
