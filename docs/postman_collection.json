{
  "info": {
    "name": "链客宝AI API",
    "description": "链客宝AI后端 API 集合 — Premium Business Network and Entrepreneur Supply-Demand Matching Platform\n\n环境变量:\n- {{base_url}}: API 基础地址 (默认: https://www.go-aiport.com)\n- {{token}}: Bearer 令牌 (登录后自动获取)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "liankebao"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://www.go-aiport.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 认证 Auth",
      "description": "用户注册、登录、令牌管理",
      "item": [
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user@example.com\",\n  \"password\": \"your_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "用户登录，返回 access_token 和 refresh_token。登录后请将 access_token 设为环境变量 {{token}}。"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.environment.set('token', json.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "用户注册",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"张三\",\n  \"phone\": \"13800138000\",\n  \"company\": \"示例科技有限公司\",\n  \"position\": \"产品经理\",\n  \"role\": \"buyer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "用户注册，支持手机号或邮箱作为用户名。自动签发 token。"
          }
        },
        {
          "name": "获取当前用户",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "获取当前登录用户的详细信息。"
          }
        },
        {
          "name": "刷新令牌",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"your_refresh_token_here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "使用 refresh_token 轮换获取新的 access_token + refresh_token。"
          }
        },
        {
          "name": "微信登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"微信小程序临时code\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/wechat",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "wechat"]
            },
            "description": "微信小程序登录，使用 wx.login() 获取的临时 code。"
          }
        },
        {
          "name": "退出登录",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "将当前 token 加入黑名单，实现登出。"
          }
        }
      ]
    },
    {
      "name": "📦 产品 Products",
      "description": "产品 CRUD 和分类浏览",
      "item": [
        {
          "name": "获取产品列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products?page=1&page_size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "category", "value": null, "disabled": true },
                { "key": "search", "value": null, "disabled": true }
              ]
            },
            "description": "获取产品列表，支持分类筛选和分页。未登录用户可见已上架产品。"
          }
        },
        {
          "name": "创建产品",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"优质农产品礼盒\",\n  \"description\": \"精选有机农产品礼盒，适合节日送礼\",\n  \"price\": 299.00,\n  \"category\": \"食品/农产品\",\n  \"tags\": \"有机,礼盒,农产品\",\n  \"stock\": 100,\n  \"images\": [\"https://example.com/image1.jpg\"],\n  \"brand\": \"链客优选\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
            },
            "description": "创建新产品（需 admin 或 member 角色）。"
          }
        },
        {
          "name": "获取产品详情",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "1"]
            },
            "description": "获取指定产品的详细信息。"
          }
        },
        {
          "name": "更新产品",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"更新后的产品名称\",\n  \"price\": 199.00,\n  \"stock\": 200\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "1"]
            },
            "description": "更新产品信息（仅本人或管理员）。"
          }
        },
        {
          "name": "删除产品",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "1"]
            },
            "description": "软删除产品。"
          }
        }
      ]
    },
    {
      "name": "🔍 搜索 Search",
      "description": "产品搜索和语义搜索",
      "item": [
        {
          "name": "产品搜索",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/search?q=有机农产品&page=1&page_size=20&sort_by=relevance",
              "host": ["{{base_url}}"],
              "path": ["api", "search"],
              "query": [
                { "key": "q", "value": "有机农产品" },
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "sort_by", "value": "relevance" },
                { "key": "category", "value": null, "disabled": true },
                { "key": "min_price", "value": null, "disabled": true },
                { "key": "max_price", "value": null, "disabled": true },
                { "key": "highlight", "value": "true", "disabled": true }
              ]
            },
            "description": "全文搜索产品，支持中文分词、分类/价格/地区筛选、多维度排序。"
          }
        },
        {
          "name": "语义向量搜索",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/search/vector?q=寻找优质供应商&top_k=10",
              "host": ["{{base_url}}"],
              "path": ["api", "search", "vector"],
              "query": [
                { "key": "q", "value": "寻找优质供应商" },
                { "key": "top_k", "value": "10" }
              ]
            },
            "description": "使用向量 embedding 做语义相似度搜索。需启用 USE_VECTOR_SEARCH=1。"
          }
        },
        {
          "name": "重建向量索引",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/search/vector/rebuild",
              "host": ["{{base_url}}"],
              "path": ["api", "search", "vector", "rebuild"]
            },
            "description": "扫描全量数据重新生成向量索引。"
          }
        }
      ]
    },
