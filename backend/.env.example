# ===================================================================
# 链客宝 Backend — 环境变量配置
# ===================================================================
# 复制此文件为 .env 并填入真实值
# ===================================================================

# ── 服务端口 ──────────────────────────────────────────────────────
PORT=8001

# ── 微信小程序配置（认证模块） ────────────────────────────────────
WX_APPID=your_wx_appid_here
WX_SECRET=your_wx_secret_here

# ── SMTP 邮件配置（通知服务模块） ────────────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code

# ── 阿里云短信配置（通知服务模块） ──────────────────────────────
ALIYUN_SMS_ACCESS_KEY=your_aliyun_access_key_id
ALIYUN_SMS_SECRET_KEY=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=链客宝
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# ── JWT 认证配置 ──────────────────────────────────────────────────
# JWT_SECRET=your_jwt_secret_key_change_this_in_production
# JWT_EXPIRY_HOURS=24

# ── Sentry APM 错误追踪 ──────────────────────────────────────────
# ⚠️ DSN 为空时 Sentry 不会初始化（代码中已做静默降级处理）。
# 注册获取 DSN → https://sentry.io/signup 创建项目后复制 Client Keys (DSN)
# 配置步骤: python scripts/sentry_config.py
SENTRY_DSN=your_dsn_here
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 结构化日志配置 ──────────────────────────────────────────────
# LOG_LEVEL=INFO               # 日志级别: DEBUG / INFO / WARNING / ERROR
#                               ↳ 排查数据库连接问题时建议临时切 DEBUG, 可看到 conn_id 追踪
# LOG_JSON=true                # JSON 格式输出 (生产环境默认启用)
# LOG_DIR=logs                 # 日志文件目录 (仅生产环境)
# LOG_MAX_BYTES=104857600      # 单文件最大字节数 (默认 100MB)
# LOG_BACKUP_COUNT=30          # 保留的轮转文件数
# APP_ENV=development          # 环境: development / production / testing
#
# ── 数据库连接池 / 日志 (用于 Docker 与本地统一配置) ─────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/db
# DATABASE_POOL_SIZE=10        # 常驻连接数 (MySQL/PostgreSQL 生效, SQLite 忽略)
# DATABASE_MAX_OVERFLOW=20     # 允许溢出的额外连接数
# DATABASE_POOL_RECYCLE=1800   # 连接回收秒数 (防止 MySQL 8h/PostgreSQL idle 断连)
# DATABASE_ECHO=false          # true/1 时回显 SQL (调试用)

# ── 支付网关配置 ──────────────────────────────────────────────────
# 微信支付 (V3 API)
WX_APPID=
WX_MCH_ID=
WX_API_V3_KEY=
WX_MCH_SERIAL_NO=
WX_PRIVATE_KEY_PATH=
WX_NOTIFY_URL=https://api.chainke.local/api/payment/callback/wxpay
WX_SANDBOX=true

# ── 微信开放平台配置（PC扫码登录）──
# 注册地址: https://open.weixin.qq.com/ → 创建网站应用
# README: 前端 liankebao.top 已支持微信扫码登录，需开放平台 AppID/Secret 激活
# OPEN_WECHAT_APPID=
# OPEN_WECHAT_SECRET=

# 支付宝
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://api.chainke.local/api/payment/callback/alipay
ALIPAY_SANDBOX=true

# ── Redis 缓存配置 ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_TTL=300              # 默认缓存 TTL（秒）
# REDIS_PREFIX=chainke:       # 缓存键前缀
# CACHE_DISABLE=0             # 设为 1 禁用缓存
