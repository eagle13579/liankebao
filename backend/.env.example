# ===================================================================
# 链客宝 Backend — 环境变量配置
# ===================================================================
# 复制此文件为 .env 并填入真实值
# ===================================================================

# ── 服务端口 ──────────────────────────────────────────────────────
PORT=8001

# ── 微信小程序配置（认证模块） ────────────────────────────────────
WX_APPID=your_wx_appid_here
WX_SECRET=your_wx_secret_here

# ── SMTP 邮件配置（通知服务模块） ────────────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code

# ── 阿里云短信配置（通知服务模块） ──────────────────────────────
ALIYUN_SMS_ACCESS_KEY=your_aliyun_access_key_id
ALIYUN_SMS_SECRET_KEY=your_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=链客宝
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# ── JWT 认证配置 ──────────────────────────────────────────────────
# JWT_SECRET=your_jwt_secret_key_change_this_in_production
# JWT_EXPIRY_HOURS=24

# ── Sentry 错误追踪 ──────────────────────────────────────────────
# SENTRY_DSN=https://your_dsn@sentry.io/your_project
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 结构化日志配置 ──────────────────────────────────────────────
# LOG_LEVEL=INFO               # 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_JSON=true                # JSON 格式输出 (生产环境默认启用)
# LOG_DIR=logs                 # 日志文件目录 (仅生产环境)
# LOG_MAX_BYTES=104857600      # 单文件最大字节数 (默认 100MB)
# LOG_BACKUP_COUNT=30          # 保留的轮转文件数
# APP_ENV=development          # 环境: development / production / testing
