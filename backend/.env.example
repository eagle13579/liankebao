# ============================================================
# 链客宝 数据库配置示例 (.env)
# ============================================================
# 复制此文件为 .env 并根据需要修改配置
# ============================================================

# -------------------------
# 数据库类型 (必选其一)
# -------------------------
# 可选值: sqlite / mysql / postgres
# DB_TYPE=sqlite

# -------------------------
# SQLite 配置 (DB_TYPE=sqlite)
# -------------------------
# SQLITE_DIR=backend/data
# SQLITE_DB_NAME=chainke.db

# -------------------------
# MySQL 配置 (DB_TYPE=mysql)
# -------------------------
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/chainke?charset=utf8mb4

# -------------------------
# PostgreSQL 配置 (DB_TYPE=postgres)
# -------------------------
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=chainke_user
# PG_PASSWORD=your_password
# PG_DATABASE=chainke_db
# 或者使用完整连接串:
# PG_URL=postgresql+psycopg2://user:pass@localhost:5432/chainke_db
