# ============================================================
# 链客宝后端 — 环境变量配置说明
# ============================================================
# 复制此文件为 .env 后按需修改

# ============================================================
# 数据库配置
# ============================================================
# 可选值: sqlite / mysql / postgres
DB_TYPE=sqlite

# SQLite 配置（DB_TYPE=sqlite 时生效）
SQLITE_DIR=./data
SQLITE_DB_NAME=chainke.db

# PostgreSQL 配置（DB_TYPE=postgres 时生效）
# PG_URL 优先级高于独立设置
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_DATABASE=liankebao

# MySQL 配置（DB_TYPE=mysql 时生效）
# DATABASE_URL=mysql+pymysql://user:pass@host:port/db?charset=utf8mb4

# ============================================================
# JWT 密钥
# ============================================================
SECRET_KEY=liankebao-jwt-secret-key-2024-nous

# ============================================================
# 服务端口
# ============================================================
PORT=7800

# ============================================================
# 多租户配置（PostgreSQL 模式强制启用）
# ============================================================
# 默认组织 slug（首次初始化时创建）
DEFAULT_ORG_SLUG=liankebao
DEFAULT_ORG_NAME=链客宝科技有限公司
DEFAULT_ORG_PLAN=enterprise

# ============================================================
# 日志级别
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Sentry 错误追踪（可选）
# ============================================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# ENV=production
