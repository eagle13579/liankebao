# ==============================================================================
# 链客宝 (LianKeBao) — 生产环境变量配置
#
# 使用方法:
#   复制本文件为 .env 并根据实际情况修改密钥和连接信息
#   所有占位符 <...> 都必须替换为实际值
#
#   source .env.production    # 加载到当前 shell
#
# 安全提醒:
#   - JWT_SECRET 务必使用强随机值: python -c "import secrets; print(secrets.token_hex(32))"
#   - DEEPSEEK_API_KEY 等密钥不要提交到版本控制
#   - 数据库密码使用强密码并定期轮换
# ==============================================================================

# ═════════════════════════════════════════════════════════════════════════════
# Phase 1 — 基础设施
# ═════════════════════════════════════════════════════════════════════════════

# INFRA_PHASE=1 激活 Phase 1 基础设施实现 (RedisCache + SQLiteEventBus)
# 设置为 0 则使用默认的 InMemoryCache 和 InMemoryEventBus 实现
INFRA_PHASE=1


# ═════════════════════════════════════════════════════════════════════════════
# 应用核心配置
# ═════════════════════════════════════════════════════════════════════════════

# JWT 签名密钥 — 256 位随机十六进制字符串（请勿使用示例值）
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<your-...ere>

# 应用名称和版本
APP_NAME=链客宝
APP_VERSION=3.1.0

# 日志级别: DEBUG / INFO / WARN / ERROR
LOG_LEVEL=INFO

# 环境标识: production / staging / development
ENVIRONMENT=production


# ═════════════════════════════════════════════════════════════════════════════
# CORS — 跨域配置
# ═════════════════════════════════════════════════════════════════════════════

# 生产环境只保留 https://liankebao.top 相关域名
CORS_ORIGINS=https://liankebao.top,https://api.liankebao.top,https://admin.liankebao.top

# CORS 预检请求缓存时间（秒）
CORS_MAX_AGE=600


# ═════════════════════════════════════════════════════════════════════════════
# 数据库 — PostgreSQL（生产环境）
# ═════════════════════════════════════════════════════════════════════════════

# 主数据库连接
# 格式: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/digital_brochure

# 同步数据库连接（用于 Alembic 迁移）
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:<password>@<host>:5432/digital_brochure

# 连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=0                         # 生产环境保持 0


# ═════════════════════════════════════════════════════════════════════════════
# Redis — 缓存与消息队列
# ═════════════════════════════════════════════════════════════════════════════

REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=***
REDIS_DB=0

# Redis 连接池配置
REDIS_POOL_MIN_SIZE=5
REDIS_POOL_MAX_SIZE=20
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=3
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# 缓存 TTL 默认值（秒）
CACHE_DEFAULT_TTL=300
CACHE_LONG_TTL=3600
CACHE_SHORT_TTL=60


# ═════════════════════════════════════════════════════════════════════════════
# AI 能力 — DeepSeek API
# ═════════════════════════════════════════════════════════════════════════════

# DeepSeek API 密钥
DEEPSEEK_API_KEY=<your-...key>

# DeepSeek API 端点
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# DeepSeek 模型配置
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=***
DEEPSEEK_TEMPERATURE=0.7


# ═════════════════════════════════════════════════════════════════════════════
# Agent Runtime — AI 数字员工
# ═════════════════════════════════════════════════════════════════════════════

AGENT_RUNTIME_MAX_CONCURRENT=5
AGENT_RUNTIME_HEARTBEAT_INTERVAL=30
AGENT_RUNTIME_TASK_TIMEOUT=120
AGENT_WORKER_COUNT=4

# 员工内存数据库路径
EMPLOYEE_MEMORY_PATH=./data/employee_memory.db

# 调度规则
AGENT_SCHEDULER_ENABLED=true
AGENT_FLYWHEEL_INTERVAL_MINUTES=30


# ═════════════════════════════════════════════════════════════════════════════
# CRM 集成 — Salesforce
# ═════════════════════════════════════════════════════════════════════════════

# SF_* 是推荐前缀; SALESFORCE_* 向后兼容
# 全部缺失时自动降级为存根 (无需配置即可运行)
# SF_INSTANCE_URL=https://your-instance.salesforce.com
# SF_CONSUMER_KEY=
# SF_CONSUMER_SECRET=*** SF_USERNAME=
# SF_PASSWORD=*** SF_SECURITY_TOKEN=*** SF_TIMEOUT=30


# ═════════════════════════════════════════════════════════════════════════════
# CRM 集成 — HubSpot
# ═════════════════════════════════════════════════════════════════════════════

# HUBSPOT_ACCESS_TOKEN=<your-...ken>
# HUBSPOT_BASE_URL=https://api.hubapi.com/crm/v3


# ═════════════════════════════════════════════════════════════════════════════
# CRM 名片交换自动匹配
# ═════════════════════════════════════════════════════════════════════════════

CRM_AUTO_MATCH_ON_EXCHANGE=true
CRM_AUTO_MATCH_ON_MATCH=true


# ═════════════════════════════════════════════════════════════════════════════
# 监控与可观测性
# ═════════════════════════════════════════════════════════════════════════════

# Sentry 配置
SENTRY_DSN=<your-sentry-dsn>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# OpenTelemetry 配置
OTEL_SERVICE_NAME=chainke-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=none
OTEL_SAMPLER=parentbased_traceidratio
OTEL_SAMPLER_ARG=0.1

# 健康检查
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8201


# ═════════════════════════════════════════════════════════════════════════════
# 服务器配置
# ═════════════════════════════════════════════════════════════════════════════

# Uvicorn 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8200
SERVER_WORKERS=4
SERVER_MAX_REQUESTS=10000
SERVER_MAX_REQUESTS_JITTER=1000
SERVER_GRACEFUL_TIMEOUT=30
SERVER_TIMEOUT_KEEP_ALIVE=5
SERVER_LIMIT_CONCURRENCY=1000
SERVER_LIMIT_MAX_REQUESTS=10000
SERVER_BACKLOG=2048

# 优雅关闭超时（秒）
GRACEFUL_SHUTDOWN_TIMEOUT=30


# ═════════════════════════════════════════════════════════════════════════════
# 速率限制
# ═════════════════════════════════════════════════════════════════════════════

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTHENTICATED=***
RATE_LIMIT_AGENT=50


# ═════════════════════════════════════════════════════════════════════════════
# 安全配置
# ═════════════════════════════════════════════════════════════════════════════

# HTTPS 强制重定向
HTTPS_REDIRECT=true

# CSRF 保护
CSRF_ENABLED=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# 安全响应头
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# 内容安全策略
CSP_DEFAULT_SRC="'self'"
CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
CSP_STYLE_SRC="'self' 'unsafe-inline'"
CSP_IMG_SRC="'self' data: https:"
CSP_CONNECT_SRC="'self' https://api.liankebao.top"
CSP_FONT_SRC="'self' data:"


# ═════════════════════════════════════════════════════════════════════════════
# 存储与文件上传
# ═════════════════════════════════════════════════════════════════════════════

UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=10
DATA_DIR=./data


# ═════════════════════════════════════════════════════════════════════════════
# 外部服务
# ═════════════════════════════════════════════════════════════════════════════

# 盖娅飞轮 — 进化大脑
GAIA_BRAIN_ENABLED=true
GAIA_EVOLUTION_INTERVAL_MINUTES=30
GAIA_MEMORY_DB_PATH=./data/gaia_memory.db

# 测试模式开关（生产环境必须为 false）
TESTING=false
