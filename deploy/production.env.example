# ===================================================================
# 链客宝 — 生产环境变量配置模板
# ===================================================================
# 复制此文件为 backend/.env 并填入真实值
# 注意：此文件包含生产配置，请勿提交真实值到 Git
# ===================================================================
#
# 部署后首次需手动填充:
#   1. cp deploy/production.env.example backend/.env
#   2. vi backend/.env
#   3. 填入所有 YOUR_xxx 占位符的真实值
#   4. 重启服务: systemctl restart chainke
#
# ===================================================================

# ── FastAPI 服务端口 ───────────────────────────────────────────────
# 生产环境建议 8001，Nginx 反向代理到 80/443
PORT=8001

# ── 运行环境 ──────────────────────────────────────────────────────
# production / staging / development
ENVIRONMENT=production
DEBUG=false

# ── 密钥与安全 ────────────────────────────────────────────────────
# ⚠️ 生产环境必须更改！
JWT_SECRET=YOUR_JWT_SECRET_KEY_CHANGE_THIS
JWT_EXPIRY_HOURS=24

# ── 数据库配置（PostgreSQL） ──────────────────────────────────────
# 格式: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://chainke:YOUR_DB_PASSWORD@localhost:5432/chainke_prod

# ── Redis 配置（缓存/消息队列） ───────────────────────────────────
# 格式: redis://:password@host:port/db
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# ── 微信小程序配置（认证模块） ────────────────────────────────────
WX_APPID=YOUR_WX_APPID
WX_SECRET=YOUR_WX_SECRET

# ── 微信支付（下单模块用） ──────────────────────────────────────
WECHAT_MCHID=YOUR_MERCHANT_ID
WECHAT_API_KEY=YOUR_WECHAT_API_KEY
WECHAT_APP_SECRET=YOUR_WECHAT_APP_SECRET

# ── 支付宝支付 ────────────────────────────────────────────────────
ALIPAY_APP_ID=YOUR_ALIPAY_APP_ID
ALIPAY_PRIVATE_KEY=YOUR_ALIPAY_PRIVATE_KEY
ALIPAY_PUBLIC_KEY=YOUR_ALIPAY_PUBLIC_KEY

# ── 阿里云短信配置 ──────────────────────────────────────────────
ALIYUN_SMS_ACCESS_KEY=YOUR_ALIYUN_ACCESS_KEY_ID
ALIYUN_SMS_SECRET_KEY=YOUR_ALIYUN_ACCESS_KEY_SECRET
ALIYUN_SMS_SIGN_NAME=链客宝
ALIYUN_SMS_TEMPLATE_CODE=SMS_YOUR_TEMPLATE_CODE

# ── SMTP 邮件配置（通知服务） ────────────────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@qq.com
SMTP_PASS=YOUR_SMTP_AUTHORIZATION_CODE

# ── Sentry 错误追踪 ──────────────────────────────────────────────
SENTRY_DSN=https://YOUR_DSN@sentry.io/YOUR_PROJECT
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CORS 允许的域名（生产环境） ──────────────────────────────────
# 多个域名用逗号分隔
CORS_ORIGINS=https://liankebao.top,https://www.liankebao.top

# ── 文件存储 ──────────────────────────────────────────────────────
# local / oss / s3
STORAGE_BACKEND=local
STORAGE_PATH=/var/www/chainke-full/storage
# 阿里云 OSS 配置（如果使用 OSS）
# OSS_ACCESS_KEY_ID=YOUR_OSS_ACCESS_KEY
# OSS_ACCESS_KEY_SECRET=YOUR_OSS_SECRET
# OSS_BUCKET=chainke-prod
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# ── AI 服务 ───────────────────────────────────────────────────────
# OpenAI / 兼容接口
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 日志级别 ──────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ── 定时任务 ──────────────────────────────────────────────────
# 工作日每天 9:00 自动生成
SCHEDULER_AUTO_GENERATE=true
SCHEDULER_TIMEZONE=Asia/Shanghai
