{
  "title": "链客宝 Backend 监控",
  "uid": "chainke-backend-monitoring",
  "version": 1,
  "schemaVersion": 38,
  "description": "链客宝后端服务核心指标仪表盘 — API 请求量、错误率、响应延迟、活跃用户",
  "tags": ["chainke", "backend", "fastapi"],
  "timezone": "browser",
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "value": "Prometheus"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "API 请求量 (RPS)",
      "type": "graph",
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(chainke_http_requests_total[1m]))",
          "legendFormat": "所有请求",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(chainke_http_requests_total{status=~\"2..\"}[1m]))",
          "legendFormat": "2xx 成功",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(chainke_http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx 客户端错误",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(chainke_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx 服务端错误",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "legend": {
          "show": true,
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      }
    },
    {
      "title": "错误率 (Error Rate)",
      "type": "graph",
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(chainke_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(chainke_http_requests_total[5m])) * 100",
          "legendFormat": "5xx 错误率 (%)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "sum(rate(chainke_http_requests_total{status=~\"4..\"}[5m])) / sum(rate(chainke_http_requests_total[5m])) * 100",
          "legendFormat": "4xx 错误率 (%)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {
          "show": true,
          "placement": "bottom"
        }
      }
    },
    {
      "title": "响应延迟 (P50 / P90 / P99)",
      "type": "graph",
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(chainke_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(chainke_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P90",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(chainke_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      },
      "options": {
        "legend": {
          "show": true,
          "placement": "bottom"
        }
      }
    },
    {
      "title": "请求耗时分布 (Heatmap)",
      "type": "heatmap",
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(chainke_http_request_duration_seconds_bucket[1m])) by (le)",
          "format": "heatmap",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "calculate": false,
        "color": {
          "mode": "spectrum"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "活跃用户数",
      "type": "stat",
      "id": 4,
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "chainke_active_users",
          "legendFormat": "活跃用户",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {
            "mode": "thresholds"
          }
        },
        "thresholds": {
          "steps": [
            {
              "color": "rgba(156, 156, 156, 1)",
              "value": null
            },
            {
              "color": "rgba(108, 211, 119, 1)",
              "value": 0
            },
            {
              "color": "rgba(245, 189, 52, 1)",
              "value": 50
            },
            {
              "color": "rgba(229, 83, 73, 1)",
              "value": 200
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "title": "各路径请求量 Top 10",
      "type": "table",
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 16
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(chainke_http_requests_total[5m])) by (path))",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "path": 0,
              "Value": 1
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "总请求数 (累计)",
      "type": "stat",
      "id": 7,
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(chainke_http_requests_total)",
          "legendFormat": "总请求数",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    }
  ]
}
