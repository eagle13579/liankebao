# =============================================================================
# 链客宝 环境变量配置文件
# 路径: /opt/liankebao/.env
# 说明: 复制本文件到 /opt/liankebao/.env 后填入实际值
#       敏感字段已留空，请勿将含敏感信息的文件提交到 Git
# 注意: 字符串值无需引号包裹，布尔值用 1/0 或 true/false
# =============================================================================

# ============================================================
# 一、应用核心配置
# ============================================================

# JWT 签名密钥（生产环境请使用 64 位以上随机字符串）
SECRET_KEY=

# 日志级别: DEBUG / INFO / WARNING / ERROR（默认 INFO）
LOG_LEVEL=INFO

# 日志输出文件路径（留空则输出到 stdout/stderr）
LOG_FILE=

# ============================================================
# 二、数据库配置
# ============================================================

# 数据库类型: sqlite / mysql / postgres（默认 sqlite）
DB_TYPE=sqlite

# 通用数据库连接串
# MySQL 示例: mysql+pymysql://user:password@host:3306/chainke?charset=utf8mb4
# PostgreSQL 示例: postgresql+psycopg2://user:password@host:5432/chainke
DATABASE_URL=

# --- PostgreSQL 独立配置（DB_TYPE=postgres 时使用）---
# 若设置了 DATABASE_URL 或 PG_URL，以下 PG_* 单项可不填
PG_URL=
PG_HOST=localhost
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=

# --- SQLite 独立配置（DB_TYPE=sqlite 时使用）---
# SQLite 数据文件目录（默认: /opt/liankebao/backend/data）
SQLITE_DIR=
# SQLite 数据库文件名（默认: chainke.db）
SQLITE_DB_NAME=chainke.db

# ============================================================
# 三、微信支付配置（wechat_pay.py — V2 版原生对接）
# ============================================================

# 小程序 AppID（wx 开头）
WEIXIN_APPID=

# 微信支付商户号（10 位数字）
MCH_ID=

# 支付签名密钥（V2 密钥，32 位，商户平台设置）
API_KEY=

# 小程序 AppSecret（微信公众平台获取）
API_SECRET=

# V3 密钥（32 位，用于回调通知解密，可选但建议设置）
APIv3_KEY=

# 支付回调通知地址（公网可访问的 HTTPS URL，需包含 /api/payment/wxpay/callback）
NOTIFY_URL=https://liankebao.top/api/payment/wxpay/callback

# 退款回调通知地址（默认同 NOTIFY_URL，不填则与 NOTIFY_URL 一致）
REFUND_NOTIFY_URL=

# 微信证书路径（退款/企业付款时需要）
# apiclient_cert.pem 的绝对路径
WECHAT_CERT_PATH=
# apiclient_key.pem 的绝对路径
WECHAT_KEY_PATH=
# rootca.pem 的绝对路径（可选）
WECHAT_ROOT_CA_PATH=

# 服务器出口 IP（统一下单/企业付款时作为 spbill_create_ip，默认 127.0.0.1）
SERVER_IP=47.100.160.250

# ============================================================
# 四、微信支付配置（payment/config.py — IJPay 封装层）
# 同时支持 WXPAY_* 和 WECHAT_* 两种前缀，WXPAY_* 优先
# 若已设置上方 WEIXIN_APPID / MCH_ID / API_KEY 等，此处可省略
# ============================================================

# 支付模式: real 为真实支付，mock 为模拟模式（默认 mock）
PAYMENT_MODE=mock

# --- 微信支付（IJPay 层，可选覆盖）---
WXPAY_APPID=
WXPAY_MCH_ID=
WXPAY_API_KEY=
WXPAY_API_V3_KEY=
WXPAY_PRIVATE_KEY_PATH=
WXPAY_CERT_SERIAL_NO=
WXPAY_NOTIFY_URL=
WXPAY_REFUND_NOTIFY_URL=
WXPAY_CERT_PATH=
WXPAY_ROOT_CA_PATH=

# --- 支付宝配置（IJPay 层）---
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_CHARSET=UTF-8
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_NOTIFY_URL=
ALIPAY_APP_CERT_PATH=
ALIPAY_ALIPAY_CERT_PATH=

# ============================================================
# 五、微信登录 / 小程序配置
# ============================================================

# 微信小程序 AppSecret（用于登录鉴权，与上方 API_SECRET 相同）
WECHAT_APP_SECRET=

# ============================================================
# 六、搜索服务配置
# ============================================================

# 搜索后端: auto / whoosh / fts5 / elasticsearch（默认 auto）
SEARCH_BACKEND=auto
# 是否使用 jieba 分词（1=启用，0=禁用，默认 1）
USE_JIEBA=1
# 强制启用 FTS5 全文搜索（1=启用，默认 0）
SEARCH_FORCE_FTS5=0
# 禁用 FTS5 全文搜索（1=禁用，默认 0）
SEARCH_DISABLE_FTS5=0

# ============================================================
# 七、第三方 API
# ============================================================

# DeepSeek AI API 密钥（用于数据导入/智能处理）
DEEPSEEK_API_KEY=
