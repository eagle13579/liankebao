.notifications { min-height: 100vh; background: #f5f5f5; }

.notif-list { padding: 24rpx; }

.notif-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  position: relative;
}
.notif-item:active { opacity: 0.9; }
.notif-item.unread { border-left: 6rpx solid #0ea5e9; }

.notif-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #ef4444;
  position: absolute;
  top: 32rpx;
  left: 20rpx;
  flex-shrink: 0;
}

.notif-body {
  flex: 1;
  margin-left: 24rpx;
}

.notif-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}
.notif-item.unread .notif-title { font-weight: 700; }

.notif-desc {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  display: block;
}

.notif-time {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
}

.notif-arrow {
  font-size: 32rpx;
  color: #94a3b8;
  margin-left: 16rpx;
  align-self: center;
}

.loading { text-align: center; padding: 120rpx 0; color: #94a3b8; font-size: 28rpx; }

.load-more { text-align: center; padding: 32rpx 0; }
.load-more-btn {
  font-size: 26rpx;
  color: #0ea5e9;
  padding: 12rpx 48rpx;
  border: 1px solid #0ea5e9;
  border-radius: 36rpx;
}
.load-more-btn:active { opacity: 0.7; }
