<view class="notifications">
  <!-- 加载状态 -->
  <block wx:if="{{loading && list.length === 0}}">
    <view class="loading">加载中...</view>
  </block>

  <!-- 空状态 -->
  <block wx:elif="{{list.length === 0 && !loading}}">
    <view class="empty-state">
      <text class="empty-state-icon">🔔</text>
      <text class="empty-state-title">暂无消息</text>
      <text class="empty-state-desc">暂时没有新的通知消息</text>
    </view>
  </block>

  <!-- 通知列表 -->
  <block wx:else>
    <view class="notif-list">
      <view class="notif-item {{item.read ? '' : 'unread'}}" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="markRead">
        <view class="notif-dot" wx:if="{{!item.read}}"></view>
        <view class="notif-body">
          <text class="notif-title">{{item.title}}</text>
          <text class="notif-desc">{{item.content || item.message}}</text>
          <text class="notif-time">{{item.created_at}}</text>
        </view>
        <text class="notif-arrow">›</text>
      </view>
    </view>
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text class="load-more-btn" bindtap="loadMore">加载更多</text>
    </view>
  </block>
</view>
