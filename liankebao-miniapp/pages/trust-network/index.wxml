<view class="page">
  <view class="search-bar"><input placeholder="搜索用户" bindinput="onSearch" value="{{searchQuery}}"/></view>
  <block wx:if="{{searchResults.length>0}}"><view class="search-results"><block wx:for="{{searchResults}}" wx:key="id">
    <view class="user-item"><text>{{item.name}} - {{item.company}}</text><button class="add-btn" data-id="{{item.user_id}}" bindtap="addTrust">添加</button></view>
  </block></view></block>
  <view class="section-title">我的信任网络 ({{trustList.length}})</view>
  <block wx:if="{{trustList.length==0}}"><view class="empty"><text>暂无信任关系</text></view></block>
  <block wx:else><block wx:for="{{trustList}}" wx:key="id">
    <view class="trust-item" data-id="{{item.user_id}}" bindlongpress="removeTrust">
      <image src="{{item.avatar||'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22%3E%3Crect width=%22100%22 height=%22100%22 fill=%22%23e5e7eb%22 rx=%2250%22/%3E%3Ctext x=%2250%22 y=%2265%22 text-anchor=%22middle%22 font-size=%2242%22 fill=%22%239ca3af%22%3E👤%3C/text%3E%3C/svg%3E'}}"/><view><text>{{item.name}}</text><text>{{item.company}}</text></view>
    </view>
  </block></block>
</view>