<view class="policy">
  <!-- 头部 -->
  <view class="header">
    <text class="header-title">合伙人政策</text>
    <text class="header-sub">三级体系 · 共享收益</text>
  </view>

  <!-- 分级体系 -->
  <view class="section">
    <text class="section-title">📊 三级合伙人体系</text>
    <view class="tier-list">
      <view class="tier-card tier-l1">
        <view class="tier-badge">L1</view>
        <text class="tier-name">初级合伙人</text>
        <text class="tier-condition">条件：推广业绩 ≥ 10,000 元</text>
        <text class="tier-benefit">收益：直接推广佣金 30% + 团队业绩奖 5%</text>
      </view>
      <view class="tier-card tier-l2">
        <view class="tier-badge">L2</view>
        <text class="tier-name">中级合伙人</text>
        <text class="tier-condition">条件：推广业绩 ≥ 50,000 元 或 团队 ≥ 10人</text>
        <text class="tier-benefit">收益：直接推广佣金 40% + 团队业绩奖 8% + 间接管理奖 2%</text>
      </view>
      <view class="tier-card tier-l3">
        <view class="tier-badge">L3</view>
        <text class="tier-name">高级合伙人</text>
        <text class="tier-condition">条件：推广业绩 ≥ 200,000 元 或 团队 ≥ 50人</text>
        <text class="tier-benefit">收益：直接推广佣金 50% + 团队业绩奖 12% + 间接管理奖 5% + 季度分红</text>
      </view>
    </view>
  </view>

  <!-- 排行榜激励 -->
  <view class="section">
    <text class="section-title">🏆 排行榜激励方案</text>
    <view class="rank-list">
      <view class="rank-item">
        <view class="rank-badge rank-1">🥇</view>
        <view class="rank-body">
          <text class="rank-name">月度冠军</text>
          <text class="rank-prize">奖励 ¥10,000 + 专属荣誉证书</text>
        </view>
      </view>
      <view class="rank-item">
        <view class="rank-badge rank-2">🥈</view>
        <view class="rank-body">
          <text class="rank-name">月度亚军</text>
          <text class="rank-prize">奖励 ¥5,000 + 专属荣誉证书</text>
        </view>
      </view>
      <view class="rank-item">
        <view class="rank-badge rank-3">🥉</view>
        <view class="rank-body">
          <text class="rank-name">月度季军</text>
          <text class="rank-prize">奖励 ¥2,000 + 专属荣誉证书</text>
        </view>
      </view>
      <view class="rank-item">
        <view class="rank-badge rank-4">🌟</view>
        <view class="rank-body">
          <text class="rank-name">新星奖</text>
          <text class="rank-prize">月度新人王，奖励 ¥1,000</text>
        </view>
      </view>
      <view class="rank-item">
        <view class="rank-badge rank-5">🚀</view>
        <view class="rank-body">
          <text class="rank-name">团队突破奖</text>
          <text class="rank-prize">团队月业绩突破100万，额外奖励 ¥20,000</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 权益说明 -->
  <view class="section">
    <text class="section-title">📋 权益说明</text>
    <view class="benefit-list">
      <view class="benefit-item">
        <text class="benefit-icon">✅</text>
        <text class="benefit-text">所有层级合伙人按月结算推广佣金</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✅</text>
        <text class="benefit-text">L2及以上合伙人享有公司季度利润分红</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✅</text>
        <text class="benefit-text">L3合伙人可参与公司年度战略会议</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✅</text>
        <text class="benefit-text">排行榜奖励每月5号前发放</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✅</text>
        <text class="benefit-text">连续3个月达标可申请晋升下一等级</text>
      </view>
    </view>
  </view>
</view>
