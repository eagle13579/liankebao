<view class="orders">
  <view class="header">
    <text>我的订单</text>
  </view>

  <view class="tabs">
    <view wx:for="{{statusTabs}}" wx:key="key" class="tab-item {{currentTab === item.key ? 'active' : ''}}" data-tab="{{item.key}}" bindtap="switchTab">
      <text>{{item.label}}</text>
    </view>
  </view>

  <scroll-view class="order-list" scroll-y>
    <block wx:if="{{loading}}">
      <text class="loading">加载中...</text>
    </block>
    <block wx:elif="{{orders.length === 0}}">
      <view class="empty-state">
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无订单</text>
      </view>
    </block>
    <block wx:else>
      <view wx:for="{{orders}}" wx:key="id" class="order-card">
        <view class="order-top">
          <view class="order-info">
            <text class="order-name">{{item.productName}}</text>
            <text class="order-no">订单号: {{item.order_no}}</text>
            <text class="order-time" wx:if="{{item.created_at}}">下单时间: {{item.created_at}}</text>
          </view>
          <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="order-body">
          <text class="order-price">¥{{item.total_price}} × {{item.quantity}}</text>
          <view class="action-btns">
            <text class="action-btn cancel-btn" wx:if="{{item.status === 'pending'}}" data-id="{{item.id}}" bindtap="handleCancel">取消</text>
            <text class="action-btn pay-btn" wx:if="{{item.status === 'pending'}}" data-id="{{item.id}}" bindtap="handlePay">去付款</text>
            <text class="action-btn ship-btn" wx:if="{{item.status === 'paid'}}" data-id="{{item.id}}" bindtap="handleShip">发货</text>
            <text class="action-btn confirm-btn" wx:if="{{item.status === 'shipped'}}" data-id="{{item.id}}" bindtap="handleConfirm">确认收货</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>
</view>
