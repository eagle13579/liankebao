.orders { min-height: 100vh; background: #f5f5f5; }
.header { padding: 60rpx 40rpx 40rpx; background: linear-gradient(135deg,#0ea5e9,#0284c7); text-align: center; }
.header text { font-size: 36rpx; font-weight: 700; color: #fff; }

.tabs { display: flex; background: #fff; padding: 0 20rpx; border-bottom: 1px solid #f1f5f9; position: sticky; top: 0; z-index: 10; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 26rpx; color: #64748b; position: relative; }
.tab-item.active { color: #0ea5e9; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 4rpx; background: #0ea5e9; border-radius: 2rpx; }

.order-list { padding: 20rpx 32rpx 40rpx; }
.order-card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.order-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.order-info { flex: 1; }
.order-name { font-size: 30rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 8rpx; }
.order-no { font-size: 22rpx; color: #94a3b8; display: block; margin-bottom: 4rpx; }
.order-time { font-size: 22rpx; color: #94a3b8; display: block; }
.order-status { font-size: 24rpx; padding: 4rpx 20rpx; border-radius: 20rpx; white-space: nowrap; }
.status-pending { color: #f59e0b; background: #fffbeb; }
.status-paid { color: #0ea5e9; background: #f0f9ff; }
.status-shipped { color: #8b5cf6; background: #f5f3ff; }
.status-completed { color: #10b981; background: #ecfdf5; }
.status-cancelled { color: #94a3b8; background: #f8fafc; }
.order-body { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f1f5f9; padding-top: 20rpx; }
.order-price { font-size: 28rpx; color: #64748b; }
.action-btns { display: flex; gap: 16rpx; }
.action-btn { font-size: 24rpx; padding: 8rpx 28rpx; border-radius: 28rpx; }
.action-btn:active { opacity: 0.8; }
.pay-btn { color: #fff; background: linear-gradient(135deg,#0ea5e9,#0284c7); }
.confirm-btn { color: #fff; background: #10b981; }
.ship-btn { color: #fff; background: #8b5cf6; }
.cancel-btn { color: #64748b; background: #f1f5f9; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #94a3b8; }
