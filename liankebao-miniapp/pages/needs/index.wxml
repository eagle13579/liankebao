<view class="needs">
  <!-- 分类筛选 -->
  <scroll-view class="categories" scroll-x enable-flex>
    <view class="category {{currentCategory === '' ? 'active' : ''}}" data-cat="" bindtap="selectCategory">全部</view>
    <view class="category {{currentCategory === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" data-cat="{{item}}" bindtap="selectCategory">{{item}}</view>
  </scroll-view>

  <!-- 加载状态 -->
  <block wx:if="{{loading && needs.length === 0}}">
    <view class="loading">加载中...</view>
  </block>

  <!-- 空状态 -->
  <block wx:elif="{{needs.length === 0 && !loading}}">
    <view class="empty-state">
      <text class="empty-state-icon">📋</text>
      <text class="empty-state-title">暂无需求</text>
      <text class="empty-state-desc">还没有人发布需求，快来发布第一条吧</text>
    </view>
  </block>

  <!-- 需求列表 -->
  <block wx:else>
    <view class="need-list">
      <view class="need-card" wx:for="{{needs}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
        <view class="need-top">
          <text class="need-title">{{item.title}}</text>
          <text class="need-status {{item.status}}">{{item.status === 'open' ? '进行中' : item.status === 'closed' ? '已关闭' : '已完成'}}</text>
        </view>
        <text class="need-category">{{item.category}}</text>
        <text class="need-desc">{{item.description}}</text>
        <view class="need-bottom">
          <text class="need-budget" wx:if="{{item.budget}}">预算 ¥{{item.budget}}</text>
          <text class="need-contact">{{item.contact || item.publisher || '匿名'}}</text>
          <text class="need-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text class="load-more-btn" bindtap="loadMore">加载更多</text>
    </view>
    <view class="load-more" wx:elif="{{needs.length > 0}}">
      <text class="load-more-done">— 已加载全部 —</text>
    </view>
  </block>

  <!-- 底部浮动发布按钮 -->
  <view class="float-btn" bindtap="goPostNeed">
    <text class="float-btn-icon">＋</text>
    <text class="float-btn-text">发布需求</text>
  </view>
</view>
