.needs { min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }

/* 分类筛选 */
.categories {
  display: flex;
  white-space: nowrap;
  padding: 12rpx 24rpx;
  margin-bottom: 8rpx;
  background: #fff;
}
.category {
  display: inline-flex;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: #f5f5f5;
  border-radius: 36rpx;
}
.category.active {
  color: #fff;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  font-weight: 600;
}

/* 需求卡片 */
.need-list { padding: 0 24rpx; }
.need-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.need-card:active { opacity: 0.9; }
.need-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.need-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
  margin-right: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.need-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}
.need-status.open { color: #10b981; background: #ecfdf5; }
.need-status.closed { color: #94a3b8; background: #f1f5f9; }
.need-status.completed { color: #0ea5e9; background: #f0f9ff; }

.need-category {
  font-size: 22rpx;
  color: #0ea5e9;
  background: #f0f9ff;
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}
.need-desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.need-bottom {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}
.need-budget {
  font-size: 28rpx;
  font-weight: 700;
  color: #f59e0b;
}
.need-contact {
  font-size: 22rpx;
  color: #94a3b8;
}
.need-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: auto;
}

/* 加载更多 */
.load-more { text-align: center; padding: 32rpx 0; }
.load-more-btn {
  font-size: 26rpx;
  color: #0ea5e9;
  padding: 12rpx 48rpx;
  border: 1px solid #0ea5e9;
  border-radius: 36rpx;
}
.load-more-btn:active { opacity: 0.7; }
.load-more-done { font-size: 24rpx; color: #94a3b8; }

/* 浮动按钮 */
.float-btn {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(14,165,233,0.4);
  z-index: 100;
}
.float-btn:active { opacity: 0.9; }
.float-btn-icon {
  font-size: 32rpx;
  font-weight: 700;
}
.float-btn-text {
  font-size: 28rpx;
  font-weight: 600;
}

.loading { text-align: center; padding: 120rpx 0; color: #94a3b8; font-size: 28rpx; }
