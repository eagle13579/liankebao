<view class="register">
  <view class="form-card">
    <view class="form-title">完善资料</view>

    <!-- 用户名 -->
    <view class="form-group">
      <text class="label">用户名</text>
      <input class="input" placeholder="请设置用户名" value="{{username}}" bindinput="onInput" data-field="username" />
    </view>

    <!-- 密码 -->
    <view class="form-group">
      <text class="label">密码</text>
      <input class="input" type="password" placeholder="请设置密码（至少6位）" value="{{password}}" bindinput="onInput" data-field="password" />
    </view>

    <!-- 姓名 -->
    <view class="form-group">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入真实姓名" value="{{name}}" bindinput="onInput" data-field="name" />
    </view>

    <!-- 手机号 -->
    <view class="form-group">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{mobile}}" bindinput="onInput" data-field="mobile" maxlength="11" />
    </view>

    <!-- 公司 -->
    <view class="form-group">
      <text class="label">公司</text>
      <input class="input" placeholder="请输入公司名称" value="{{company}}" bindinput="onInput" data-field="company" />
    </view>

    <!-- 职位 -->
    <view class="form-group">
      <text class="label">职位</text>
      <input class="input" placeholder="请输入职位" value="{{position}}" bindinput="onInput" data-field="position" />
    </view>

    <!-- 身份选择 -->
    <view class="form-group">
      <text class="label">身份</text>
      <view class="role-group">
        <view class="role-item {{role === 'business' ? 'active' : ''}}" data-role="business" bindtap="selectRole">
          <text class="role-icon">🏢</text>
          <text class="role-text">企业主</text>
        </view>
        <view class="role-item {{role === 'promoter' ? 'active' : ''}}" data-role="promoter" bindtap="selectRole">
          <text class="role-icon">📣</text>
          <text class="role-text">推广员</text>
        </view>
        <view class="role-item {{role === 'supplier' ? 'active' : ''}}" data-role="supplier" bindtap="selectRole">
          <text class="role-icon">📦</text>
          <text class="role-text">产品方</text>
        </view>
      </view>
    </view>

    <!-- 用户协议 -->
    <view class="agreement">
      <text class="checkbox {{agreed ? 'checked' : ''}}" bindtap="toggleAgree">{{agreed ? '✓' : ''}}</text>
      <text class="agree-text">我已阅读并同意</text>
      <text class="agree-link" bindtap="showAgreement">《用户服务协议》</text>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn" bindtap="handleSubmit" disabled="{{!agreed || submitting}}">
      <text wx:if="{{submitting}}">提交中...</text>
      <text wx:else>完成注册</text>
    </button>

    <view class="login-link">
      <text>已有账号？</text>
      <text class="link" bindtap="goLogin">去登录</text>
    </view>
  </view>
</view>
