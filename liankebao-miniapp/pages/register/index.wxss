.register { min-height: 100vh; background: #f5f5f5; padding: 32rpx 0 80rpx; }
.form-card {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.form-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 40rpx;
}
.form-group { margin-bottom: 28rpx; }
.label {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}
.input {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 28rpx;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1a1a2e;
}
.input:focus { border-color: #0ea5e9; }

/* 身份选择 */
.role-group { display: flex; gap: 16rpx; }
.role-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: #f8fafc;
  border: 2px solid #e2e8f0;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.role-item.active {
  border-color: #0ea5e9;
  background: #f0f9ff;
}
.role-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.role-text { font-size: 24rpx; color: #64748b; font-weight: 500; }
.role-item.active .role-text { color: #0ea5e9; }

/* 用户协议 */
.agreement {
  display: flex;
  align-items: center;
  margin: 32rpx 0 28rpx;
}
.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2px solid #cbd5e1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.checkbox.checked {
  background: #0ea5e9;
  border-color: #0ea5e9;
}
.agree-text { font-size: 24rpx; color: #64748b; }
.agree-link { font-size: 24rpx; color: #0ea5e9; }

/* 提交按钮 */
.submit-btn {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}
.submit-btn:active { opacity: 0.9; }
.submit-btn[disabled] {
  background: #cbd5e1;
  color: #94a3b8;
}

.login-link { text-align: center; font-size: 26rpx; color: #64748b; }
.login-link .link { color: #0ea5e9; margin-left: 4rpx; }
