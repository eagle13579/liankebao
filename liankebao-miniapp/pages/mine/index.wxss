/* pages/mine/index.wxss */
.mine-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  padding-bottom: 160rpx;
}

/* 导航 */
.mine-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 32rpx 24rpx;
}
.nav-title { font-size: 36rpx; font-weight: 700; color: #f1f5f9; }
.nav-settings { font-size: 36rpx; padding: 8rpx; }

/* 未登录 */
.unlogin-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.unlogin-avatar { font-size: 120rpx; margin-bottom: 16rpx; }
.unlogin-text { font-size: 32rpx; color: #94a3b8; margin-bottom: 32rpx; }
.login-btn { width: 400rpx; }

/* 用户信息 */
.user-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}
.user-info-row {
  display: flex;
  align-items: center;
}
.user-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 55rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.3);
}
.avatar-text { font-size: 48rpx; font-weight: 700; color: #fff; }
.user-details { flex: 1; }
.user-name { font-size: 36rpx; font-weight: 700; color: #f1f5f9; display: block; }
.user-company { font-size: 24rpx; color: #94a3b8; display: block; margin-top: 4rpx; }
.membership-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f5576c, #ff6b6b);
}
.badge-text { font-size: 22rpx; font-weight: 600; color: #fff; }

/* 数据看板 */
.data-board {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx;
  padding: 28rpx 16rpx;
}
.data-item {
  flex: 1;
  text-align: center;
}
.data-num { font-size: 44rpx; font-weight: 700; color: #f1f5f9; display: block; }
.data-label { font-size: 22rpx; color: #64748b; display: block; margin-top: 4rpx; }
.data-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.08);
}

/* 菜单列表 */
.menu-list {
  margin: 0 32rpx 24rpx;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 24rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 32rpx;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: rgba(255,255,255,0.04); }
.menu-left { display: flex; align-items: center; gap: 16rpx; }
.menu-left text:last-child { font-size: 28rpx; color: #e2e8f0; }
.menu-icon { font-size: 32rpx; }
.menu-right { display: flex; align-items: center; gap: 8rpx; }
.arrow { font-size: 36rpx; color: #64748b; font-weight: 300; }

.unread-badge {
  font-size: 20rpx;
  color: #fff;
  background: #ef4444;
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  min-width: 36rpx;
  text-align: center;
  line-height: 1.6;
}
.membership-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #f5576c, #ff6b6b);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

/* 升级推荐 */
.upgrade-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 32rpx 24rpx;
  padding: 24rpx 28rpx;
  border: 1px solid rgba(245,87,108,0.2);
}
.banner-content { display: flex; align-items: center; flex: 1; }
.banner-icon { font-size: 40rpx; margin-right: 16rpx; }
.banner-text { flex: 1; }
.banner-title { font-size: 26rpx; font-weight: 600; color: #f1f5f9; display: block; }
.banner-desc { font-size: 22rpx; color: #94a3b8; display: block; margin-top: 4rpx; }
.banner-action { font-size: 24rpx; color: #f5576c; font-weight: 600; flex-shrink: 0; }

/* 退出 */
.logout-btn {
  margin: 16rpx 32rpx 0;
  height: 92rpx;
  line-height: 92rpx;
  background: rgba(255,255,255,0.04);
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 500;
  border: 1px solid rgba(239,68,68,0.2);
  border-radius: 24rpx;
  text-align: center;
}
.logout-btn::after { border: none; }
.logout-btn:active { background: rgba(239,68,68,0.1); }
