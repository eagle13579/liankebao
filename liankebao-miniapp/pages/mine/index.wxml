<view class="container">
  <!-- 用户信息 -->
  <view class="user-card" bindtap="goToProfile">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" />
    <view class="user-detail">
      <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
      <text class="user-desc">{{userInfo.company || userInfo.bio || ''}}</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="index" bindtap="onMenuItemTap" data-page="{{item.page}}" data-index="{{index}}">
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-text">{{item.text}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
