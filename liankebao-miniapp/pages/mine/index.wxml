<view class="mine">
  <view class="user-section">
    <view class="avatar">
      <text class="avatar-text">{{userInitial}}</text>
    </view>
    <text class="user-name">{{userName}}</text>
    <text class="user-role">{{userRole}}</text>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goOrders">
      <text>我的订单</text>
      <text class="arrow">&gt;</text>
    </view>
    <view class="menu-item" wx:if="{{isPromoter}}">
      <text>推广收益</text>
      <text class="arrow">&gt;</text>
    </view>
    <view class="menu-item" wx:if="{{isSupplier}}">
      <text>产品管理</text>
      <text class="arrow">&gt;</text>
    </view>
  </view>

  <button class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="handleLogout">退出登录</button>
</view>
