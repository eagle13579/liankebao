<view class="mine">
  <view class="user-section">
    <view class="avatar">
      <text class="avatar-text">{{userInitial}}</text>
    </view>
    <text class="user-name">{{userName}}</text>
    <text class="user-role">{{userRole}}</text>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goOrders">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text>我的订单</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goNotifications">
      <view class="menu-left">
        <text class="menu-icon">🔔</text>
        <text>消息中心</text>
      </view>
      <view class="menu-right">
        <text class="unread-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goPartnerPolicy">
      <view class="menu-left">
        <text class="menu-icon">🤝</text>
        <text>合伙人政策</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isPromoter}}" bindtap="goPromotion">
      <view class="menu-left">
        <text class="menu-icon">📢</text>
        <text>推广收益</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{isSupplier}}" bindtap="goManageProducts">
      <view class="menu-left">
        <text class="menu-icon">🛍️</text>
        <text>产品管理</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAddress">
      <view class="menu-left">
        <text class="menu-icon">📍</text>
        <text>地址管理</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text>关于我们</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="handleLogout">退出登录</button>
</view>
