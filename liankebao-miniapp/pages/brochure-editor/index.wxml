<view class="page">
  <view class="progress"><block wx:for="{{maxStep}}" wx:for-index="i"><view class="dot {{i+1<=step?'active':''}}">{{i+1}}</view></block></view>
  <text class="step-label">步骤 {{step}}/{{maxStep}}</text>
  <block wx:if="{{step==1}}">
    <view class="form-group"><input placeholder="* 姓名" data-field="name" bindinput="onInput" value="{{form.name}}"/></view>
    <view class="form-group"><input placeholder="* 公司" data-field="company" bindinput="onInput" value="{{form.company}}"/></view>
    <view class="form-group"><input placeholder="职位" data-field="position" bindinput="onInput" value="{{form.position}}"/></view>
    <view class="form-group"><textarea placeholder="个人简介" data-field="bio" bindinput="onInput" value="{{form.bio}}"/></view>
  </block>
  <block wx:elif="{{step==2}}">
    <view class="form-group"><input placeholder="* 手机" data-field="phone" bindinput="onInput" value="{{form.phone}}" type="number"/></view>
    <view class="form-group"><input placeholder="微信" data-field="wechat" bindinput="onInput" value="{{form.wechat}}"/></view>
    <view class="form-group"><input placeholder="邮箱" data-field="email" bindinput="onInput" value="{{form.email}}"/></view>
  </block>
  <block wx:elif="{{step==3}}">
    <block wx:for="{{form.products}}" wx:key="index"><view class="product-item">
      <input placeholder="名称" value="{{item.name}}"/><input placeholder="价格" value="{{item.price}}" type="number"/>
      <button class="del-btn" data-index="{{index}}" bindtap="removeProduct">删除</button>
    </view></block>
    <button class="add-btn" bindtap="addProduct">+ 添加产品</button>
  </block>
  <block wx:elif="{{step==4}}">
    <picker range="{{['供应','需求']}}" bindchange="onTypeChange"><text>{{form.needType || '选择类型'}}</text></picker>
    <view class="form-group"><input placeholder="* 标题" data-field="needTitle" bindinput="onInput"/></view>
    <view class="form-group"><textarea placeholder="* 描述" data-field="needDesc" bindinput="onInput"/></view>
  </block>
  <block wx:elif="{{step==5}}">
    <view class="form-group"><input placeholder="搜索用户添加信任" /></view>
    <text class="hint">已信任: {{form.trustIds.length}}人</text>
  </block>
  <block wx:elif="{{step==6}}">
    <view class="preview-card"><text class="preview-name">{{form.name || '姓名'}}</text><text>{{form.company}} · {{form.position}}</text></view>
    <button class="submit-btn {{submitting?'disabled':''}}" bindtap="submit" disabled="{{submitting}}">{{submitting?'提交中...':'发布画册'}}</button>
  </block>
  <view class="bottom-bar"><button class="prev-btn" bindtap="prev" wx:if="{{step>1}}">上一步</button><button class="next-btn" bindtap="next" wx:if="{{step<maxStep}}">下一步</button></view>
</view>