.page{padding:20rpx;min-height:100vh;background:#f5f5f5}.btn{width:100%;height:88rpx;background:#0ea5e9;color:#fff;border-radius:16rpx;margin-top:20rpx}.btn.secondary{background:#fff;color:#0ea5e9;border:2rpx solid #0ea5e9}.skeleton{animation:shimmer 1.5s infinite}.profile-card{background:linear-gradient(135deg,#0ea5e9,#0284c7);padding:40rpx;border-radius:24rpx;color:#fff;text-align:center}.name{font-size:36rpx;font-weight:bold}.company{font-size:24rpx;opacity:.8}.section{margin-top:30rpx;background:#fff;border-radius:16rpx;padding:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06)}.section-title{font-size:28rpx;font-weight:bold;margin-bottom:16rpx;display:block}.form-group{margin-bottom:20rpx}.form-group input,.form-group textarea{width:100%;height:80rpx;background:#fff;border:2rpx solid #e5e7eb;border-radius:12rpx;padding:0 20rpx;font-size:26rpx}.form-group textarea{height:160rpx;padding:16rpx}.bottom-bar{position:fixed;bottom:0;left:0;right:0;display:flex;padding:20rpx;background:#fff;border-top:2rpx solid #e5e7eb;gap:20rpx}.next-btn{flex:1;background:#0ea5e9;color:#fff;height:80rpx;border-radius:12rpx}.prev-btn{flex:1;background:#f5f5f5;color:#666;height:80rpx;border-radius:12rpx}.progress{display:flex;justify-content:center;gap:16rpx;margin:20rpx 0}.dot{width:40rpx;height:40rpx;border-radius:50%;background:#e5e7eb;display:flex;align-items:center;justify-content:center;font-size:20rpx}.dot.active{background:#0ea5e9;color:#fff}.step-label{text-align:center;font-size:24rpx;color:#666;margin-bottom:20rpx;display:block}.qr-area{background:#fff;border-radius:24rpx;padding:60rpx;text-align:center;margin:40rpx}.qr-img{width:400rpx;height:400rpx;margin:0 auto}.trust-item{display:flex;align-items:center;gap:20rpx;padding:20rpx;background:#fff;border-radius:12rpx;margin-bottom:12rpx}.trust-item image{width:80rpx;height:80rpx;border-radius:50%}.empty{text-align:center;padding:60rpx 0;color:#999}.search-bar{margin-bottom:20rpx}.search-bar input{background:#fff;border-radius:12rpx;padding:16rpx 20rpx;font-size:26rpx}.add-btn{background:#0ea5e9;color:#fff;padding:8rpx 24rpx;border-radius:8rpx;font-size:22rpx}