.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f7fa;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.qrcode-wrapper {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 1px solid #eee;
}

.qrcode {
  width: 360rpx;
  height: 360rpx;
}

.qrcode-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  color: #999;
  font-size: 28rpx;
}

.brochure-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-top: 10rpx;
}

.stats-section {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #07c160;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.actions {
  margin-bottom: 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
  border: none;
}

.btn-primary {
  background: #07c160;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #333;
  border: 1px solid #ddd;
}

.tips {
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #aaa;
}
