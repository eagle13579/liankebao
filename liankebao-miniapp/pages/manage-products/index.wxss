.manage-products { min-height: 100vh; background: #f5f5f5; }
.header { padding: 60rpx 40rpx 40rpx; background: linear-gradient(135deg,#0ea5e9,#0284c7); text-align: center; }
.header text { font-size: 36rpx; font-weight: 700; color: #fff; }

.product-list { padding: 32rpx; }
.product-card { background: #fff; border-radius: 20rpx; margin-bottom: 20rpx; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.product-body { display: flex; padding: 32rpx; }
.product-thumb { width: 160rpx; height: 160rpx; border-radius: 16rpx; margin-right: 24rpx; }
.product-thumb-placeholder { width: 160rpx; height: 160rpx; border-radius: 16rpx; margin-right: 24rpx; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.product-name { font-size: 28rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 8rpx; }
.product-price { font-size: 32rpx; font-weight: 700; color: #0ea5e9; display: block; margin-bottom: 8rpx; }
.product-earn { font-size: 24rpx; color: #10b981; display: inline-block; background: #ecfdf5; padding: 2rpx 16rpx; border-radius: 16rpx; }

.product-actions { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 32rpx; border-top: 1px solid #f1f5f9; }
.status-badge { font-size: 22rpx; padding: 4rpx 20rpx; border-radius: 20rpx; }
.status-badge.active { color: #10b981; background: #ecfdf5; }
.status-badge.inactive { color: #94a3b8; background: #f1f5f9; }
.action-btns { display: flex; gap: 16rpx; }
.action-btn { font-size: 24rpx; padding: 6rpx 24rpx; border-radius: 24rpx; }
.action-btn:active { opacity: 0.8; }
.edit-btn { color: #64748b; background: #f1f5f9; }
.toggle-btn.off { color: #ef4444; background: #fef2f2; }
.toggle-btn.on { color: #fff; background: linear-gradient(135deg,#0ea5e9,#0284c7); }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #94a3b8; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: #cbd5e1; }
