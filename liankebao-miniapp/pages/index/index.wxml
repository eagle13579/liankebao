<view class="index">
  <!-- 头部 -->
  <view class="header">
    <view class="header-top">
      <text class="logo">链客宝</text>
      <text class="header-subtitle">企业家供需匹配平台</text>
    </view>
    <view class="header-search" bindtap="goPool">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索AI名片、GEO诊断...</text>
    </view>
  </view>

  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="skeleton">
      <!-- 骨架屏 - 轮播占位 -->
      <view class="skeleton-banner"></view>
      <!-- 骨架屏 - 分类导航占位 -->
      <view class="skeleton-nav">
        <view class="skeleton-nav-item"></view>
        <view class="skeleton-nav-item"></view>
        <view class="skeleton-nav-item"></view>
        <view class="skeleton-nav-item"></view>
      </view>
      <!-- 骨架屏 - 区块标题占位 -->
      <view class="skeleton-section-header">
        <view class="skeleton-title-block"></view>
        <view class="skeleton-more-block"></view>
      </view>
      <!-- 骨架屏 - 推荐列表占位 -->
      <view class="skeleton-list">
        <view class="skeleton-item">
          <view class="skeleton-item-img"></view>
          <view class="skeleton-item-body">
            <view class="skeleton-line skeleton-line-60"></view>
            <view class="skeleton-line skeleton-line-40"></view>
            <view class="skeleton-line skeleton-line-30"></view>
          </view>
        </view>
        <view class="skeleton-item">
          <view class="skeleton-item-img"></view>
          <view class="skeleton-item-body">
            <view class="skeleton-line skeleton-line-60"></view>
            <view class="skeleton-line skeleton-line-40"></view>
            <view class="skeleton-line skeleton-line-30"></view>
          </view>
        </view>
        <view class="skeleton-item">
          <view class="skeleton-item-img"></view>
          <view class="skeleton-item-body">
            <view class="skeleton-line skeleton-line-60"></view>
            <view class="skeleton-line skeleton-line-40"></view>
            <view class="skeleton-line skeleton-line-30"></view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 正常内容 -->
  <block wx:else>
    <!-- 轮播图 -->
    <swiper class="banner" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{4000}}" duration="{{500}}" circular="{{true}}">
      <swiper-item wx:for="{{banners}}" wx:key="index">
        <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <!-- 分类导航 -->
    <view class="nav-grid">
      <view class="nav-item" data-cat="AI名片" bindtap="goPoolWithCat">
        <view class="nav-icon nav-icon-1">🪪</view>
        <text class="nav-label">AI名片</text>
      </view>
      <view class="nav-item" data-cat="GEO诊断" bindtap="goPoolWithCat">
        <view class="nav-icon nav-icon-2">📍</view>
        <text class="nav-label">GEO诊断</text>
      </view>
      <view class="nav-item" data-cat="数字分身" bindtap="goPoolWithCat">
        <view class="nav-icon nav-icon-3">🧑‍💻</view>
        <text class="nav-label">数字分身</text>
      </view>
      <view class="nav-item" data-cat="" bindtap="goPool">
        <view class="nav-icon nav-icon-4">📦</view>
        <text class="nav-label">全部产品</text>
      </view>
    </view>

    <!-- 为您推荐 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">为您推荐</text>
        <text class="section-more" bindtap="goPool">查看更多 &gt;</text>
      </view>
    </view>

    <block wx:if="{{recommendProducts.length === 0}}">
      <text class="empty">暂无推荐产品</text>
    </block>
    <block wx:else>
      <view class="recommend-list">
        <view class="recommend-item" wx:for="{{recommendProducts}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
          <image class="recommend-img" src="{{item.firstImage}}" mode="aspectFill" />
          <view class="recommend-body">
            <text class="recommend-name">{{item.name}}</text>
            <text class="recommend-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="recommend-bottom">
              <text class="recommend-price">¥{{item.price}}</text>
              <text class="recommend-earn" wx:if="{{item.earn_per_share > 0}}">推广赚 ¥{{item.earn_per_share}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>
</view>
