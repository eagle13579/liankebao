.index { min-height: 100vh; background: #f5f5f5; }
.header { padding: 60rpx 32rpx 40rpx; background: linear-gradient(135deg,#0ea5e9,#0284c7); color: #fff; }
.logo { font-size: 48rpx; font-weight: 700; }
.subtitle { font-size: 28rpx; opacity: 0.8; margin-top: 8rpx; display: block; }
.product-list { padding: 16rpx 0; }
.product-item { display: flex; background: #fff; border-radius: 16rpx; margin: 10rpx 32rpx; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.thumb { width: 280rpx; height: 280rpx; flex-shrink: 0; }
.product-item .body { flex:1; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.product-item .name { font-size: 28rpx; font-weight: 600; color: #1a1a2e; }
.product-item .price { font-size: 36rpx; font-weight: 700; color: #f59e0b; }
.product-item .earn { font-size: 22rpx; color: #0ea5e9; background: #f0f9ff; padding: 4rpx 16rpx; border-radius: 8rpx; align-self: flex-start; }
.loading,.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }
