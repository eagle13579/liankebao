.index { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }

/* 头部 */
.header {
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  padding: 60rpx 32rpx 40rpx;
}
.header-top { margin-bottom: 24rpx; }
.logo { font-size: 48rpx; font-weight: 700; color: #fff; }
.header-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; display: block; }

/* 搜索框 */
.header-search {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  border-radius: 48rpx;
  padding: 20rpx 32rpx;
  backdrop-filter: blur(4px);
}
.header-search .search-icon { font-size: 28rpx; margin-right: 12rpx; }
.header-search .search-placeholder { font-size: 26rpx; color: rgba(255,255,255,0.7); flex: 1; }
.header-search:active { opacity: 0.8; }

/* 轮播 */
.banner {
  width: 100%;
  height: 300rpx;
  margin-top: -20rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 分类导航 */
.nav-grid {
  display: flex;
  margin: -32rpx 24rpx 16rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 8rpx;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}
.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0;
}
.nav-item:active { opacity: 0.7; }
.nav-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}
.nav-icon-1 { background: #f0f9ff; }
.nav-icon-2 { background: #fef2f2; }
.nav-icon-3 { background: #f0fdf4; }
.nav-icon-4 { background: #fffbeb; }
.nav-label { font-size: 24rpx; color: #1a1a2e; font-weight: 500; }

/* 区块标题 */
.section { padding: 24rpx 32rpx 16rpx; }
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.section-title { font-size: 32rpx; font-weight: 700; color: #1a1a2e; }
.section-more { font-size: 24rpx; color: #0ea5e9; }
.section-more:active { opacity: 0.7; }

/* 推荐列表 */
.recommend-list { padding: 0 24rpx; }
.recommend-item {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.recommend-item:active { opacity: 0.9; }
.recommend-img {
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}
.recommend-body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.recommend-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.recommend-desc {
  font-size: 22rpx;
  color: #94a3b8;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 6rpx;
}
.recommend-bottom { display: flex; align-items: center; gap: 16rpx; }
.recommend-price { font-size: 34rpx; font-weight: 700; color: #f59e0b; }
.recommend-earn {
  font-size: 20rpx;
  color: #0ea5e9;
  background: #f0f9ff;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }
.bottom-spacer { height: 120rpx; }

/* ===== 骨架屏 ===== */
@keyframes skeleton-shimmer {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.skeleton {
  padding: 0 24rpx;
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

/* 骨架 - 轮播 */
.skeleton-banner {
  width: 100%;
  height: 300rpx;
  background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
  background-size: 200% 100%;
  border-radius: 24rpx;
  margin-top: 24rpx;
}

/* 骨架 - 分类导航 */
.skeleton-nav {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 8rpx;
  margin-top: 16rpx;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.skeleton-nav-item {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #e2e8f0;
}

/* 骨架 - 区块标题 */
.skeleton-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0 16rpx;
}
.skeleton-title-block {
  width: 160rpx;
  height: 32rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
}
.skeleton-more-block {
  width: 120rpx;
  height: 28rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
}

/* 骨架 - 推荐列表 */
.skeleton-list { margin-top: 8rpx; }
.skeleton-item {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.skeleton-item-img {
  width: 240rpx;
  height: 240rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}
.skeleton-item-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
}
.skeleton-line {
  height: 24rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
}
.skeleton-line-60 { width: 60%; }
.skeleton-line-40 { width: 40%; }
.skeleton-line-30 { width: 30%; }
