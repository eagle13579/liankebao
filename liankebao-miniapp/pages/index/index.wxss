/* pages/index/index.wxss */
.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  padding-bottom: 160rpx;
}

/* 导航栏 */
.home-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 32rpx 24rpx;
  position: relative;
  z-index: 10;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f1f5f9;
}
.nav-actions {
  display: flex;
  gap: 16rpx;
}
.nav-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

/* 骨架 */
.skeleton-container {
  padding: 40rpx 32rpx;
}
.skeleton-card {
  height: 700rpx;
  border-radius: 32rpx;
}

/* 翻页容器 */
.flipbook-container {
  position: relative;
  padding: 0 24rpx;
  min-height: 700rpx;
}

/* 翻页卡片 */
.flip-page {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  opacity: 0;
  transform: scale(0.92) translateX(60rpx);
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}
.flip-page.active {
  opacity: 1;
  transform: scale(1) translateX(0);
  position: relative;
  left: 0;
  right: 0;
  pointer-events: auto;
}

.page-card {
  min-height: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx;
}

/* 封面卡片 */
.cover-card { text-align: center; }
.avatar-section { margin-bottom: 24rpx; }
.avatar-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.3);
}
.avatar-text { font-size: 60rpx; font-weight: 700; color: #fff; }
.user-name { font-size: 44rpx; font-weight: 700; color: #f1f5f9; display: block; margin-bottom: 8rpx; }
.user-company { font-size: 26rpx; color: #94a3b8; display: block; margin-bottom: 12rpx; }
.user-bio { font-size: 24rpx; color: #64748b; display: block; line-height: 1.5; margin-top: 12rpx; }

.purpose-section { margin: 16rpx 0; }
.purpose-badge {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  background: rgba(245, 87, 108, 0.15);
  color: #f5576c;
  border: 1px solid rgba(245, 87, 108, 0.3);
}

.tags-section { width: 100%; margin-top: 16rpx; }
.tag-group { margin-bottom: 16rpx; text-align: left; }
.tag-label { font-size: 24rpx; color: #94a3b8; display: block; margin-bottom: 8rpx; }
.tags { display: flex; flex-wrap: wrap; }
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}
.tag-provide { background: rgba(102, 126, 234, 0.15); color: #818cf8; }
.tag-need { background: rgba(245, 87, 108, 0.15); color: #f5576c; }

/* 联系方式卡片 */
.contact-card { text-align: left; }
.page-title { font-size: 32rpx; font-weight: 600; color: #f1f5f9; margin-bottom: 32rpx; display: block; text-align: center; }
.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.contact-item:last-child { border-bottom: none; }
.contact-icon { font-size: 32rpx; margin-right: 20rpx; width: 48rpx; text-align: center; }
.contact-value { font-size: 30rpx; color: #e2e8f0; }
.contact-empty { text-align: center; padding: 40rpx; color: #64748b; }

/* 企业信息卡片 */
.company-card { text-align: left; }
.info-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  width: 100%;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #94a3b8; width: 120rpx; flex-shrink: 0; }
.info-value { font-size: 28rpx; color: #e2e8f0; flex: 1; }

/* 二维码卡片 */
.qrcode-card { text-align: center; }
.qrcode-area {
  width: 360rpx;
  height: 360rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx auto;
}
.qrcode-placeholder {
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
}
.qrcode-icon { font-size: 120rpx; display: block; margin-bottom: 16rpx; }
.qrcode-hint { font-size: 22rpx; color: #64748b; }

/* 分页指示器 */
.page-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 16rpx 0;
}
.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.2);
  transition: all 0.3s;
}
.indicator-dot.active {
  width: 40rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  padding: 0 32rpx;
  text-align: center;
}
.action-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 48rpx;
}
.action-btn {
  flex: 1;
  height: 80rpx;
  background: rgba(255,255,255,0.08);
  color: #e2e8f0;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-btn::after { border: none; }
.action-btn:active { background: rgba(255,255,255,0.15); }
.action-btn.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(102,126,234,0.3);
}
.view-stats {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #64748b;
}

/* 空状态居中 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
  text-align: center;
}
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 36rpx; font-weight: 600; color: #f1f5f9; margin-bottom: 16rpx; }
.empty-desc { font-size: 26rpx; color: #94a3b8; margin-bottom: 40rpx; line-height: 1.5; }
