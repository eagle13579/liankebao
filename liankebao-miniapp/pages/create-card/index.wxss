/* 链客宝AI数字名片 - 自助创建页面（深色毛玻璃风格） */

page {
  background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 30%, #16213e 70%, #0f3460 100%);
  min-height: 100vh;
}

.create-card-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx 30rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 顶栏 ===== */
.header-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 30rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 32rpx;
}

.back-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 300;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 64rpx;
}

/* ===== 信息卡片 ===== */
.step-card {
  width: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 50rpx;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 32rpx;
  box-shadow:
    0 8rpx 40rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

/* 毛玻璃高光线 */
.step-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
}

/* ===== 头像图标 ===== */
.step-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(64, 224, 208, 0.4);
  margin-bottom: 30rpx;
  overflow: hidden;
}

.step-icon-img {
  width: 100%;
  height: 100%;
}

/* ===== 用户预览 ===== */
.user-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(64, 224, 208, 0.4);
  margin-bottom: 20rpx;
}

.preview-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

/* ===== 标题/说明 ===== */
.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-align: center;
}

.step-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

/* ===== 主按钮 ===== */
.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: 44rpx;
  text-align: center;
  padding: 0;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.3);
}

.primary-btn[disabled] {
  opacity: 0.5;
}

/* ===== 错误提示 ===== */
.error-text {
  color: #ff6b6b;
  font-size: 24rpx;
  margin-top: 20rpx;
  text-align: center;
}

/* ===== 表单 ===== */
.form-group {
  width: 100%;
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #fff;
}

.form-placeholder {
  color: rgba(255, 255, 255, 0.3);
  font-size: 28rpx;
}

/* ===== 成功图标 ===== */
.success-icon {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 50rpx;
  color: #40e0d0;
  background: rgba(64, 224, 208, 0.15);
  border-radius: 50%;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(64, 224, 208, 0.3);
}

/* ===== 底部隐私说明 ===== */
.privacy-notice {
  margin-top: 60rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  line-height: 1.8;
}

.privacy-notice text {
  display: block;
}
