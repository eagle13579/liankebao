<view class="page">
  <!-- 骨架屏（加载中） -->
  <block wx:if="{{loading}}">
    <view class="skeleton-wrap">
      <!-- 轮播图占位 -->
      <view class="skeleton-swiper"></view>
      <!-- 信息卡片占位 -->
      <view class="skeleton-card">
        <view class="skeleton-title skeleton"></view>
        <view class="skeleton-title skeleton skeleton-title-short"></view>
        <view class="skeleton-price skeleton"></view>
        <view class="skeleton-desc skeleton"></view>
        <view class="skeleton-desc skeleton skeleton-desc-short"></view>
      </view>
      <!-- 参数占位 -->
      <view class="skeleton-params">
        <view class="skeleton skeleton-param-row"></view>
        <view class="skeleton skeleton-param-row"></view>
        <view class="skeleton skeleton-param-row skeleton-param-row-last"></view>
      </view>
    </view>
  </block>

  <!-- 产品不存在 -->
  <block wx:elif="{{!product}}">
    <view class="empty-wrap">
      <view class="empty-state">
        <text class="empty-state-icon">🔍</text>
        <text class="empty-state-title">产品不存在</text>
        <text class="empty-state-desc">该商品可能已下架或链接有误</text>
      </view>
    </view>
  </block>

  <!-- 产品详情 -->
  <block wx:else>
    <scroll-view class="scroll-area" scroll-y="true">
      <!-- 图片轮播 -->
      <swiper class="swiper"
        indicator-dots="{{imageList.length > 1}}"
        indicator-color="rgba(255,255,255,0.4)"
        indicator-active-color="#0ea5e9"
        autoplay="{{imageList.length > 1}}"
        interval="4000"
        circular="{{imageList.length > 1}}">
        <swiper-item wx:for="{{imageList.length > 0 ? imageList : ['']}}" wx:key="*this">
          <image class="swiper-image"
            src="{{item}}"
            mode="aspectFill"
            bindtap="handlePreviewImage"
            data-url="{{item}}" />
        </swiper-item>
      </swiper>

      <!-- 没有图片时显示占位 -->
      <image wx:if="{{imageList.length === 0}}" class="swiper-image placeholder-img"
        src="/images/product-placeholder.png"
        mode="aspectFit" />

      <!-- 基础信息卡片 -->
      <view class="info-card">
        <text class="product-name">{{product.name}}</text>
        <text class="product-price">¥{{product.price}}</text>
        <text class="product-earn" wx:if="{{product.earn_per_share > 0}}">
          推广赚 ¥{{product.earn_per_share}}
        </text>
        <text class="product-desc">{{product.description}}</text>
      </view>

      <!-- 参数面板 -->
      <view class="params-card" wx:if="{{product.specText || product.category || product.stock || product.sales_count}}">
        <text class="params-title">商品参数</text>
        <view class="params-list">
          <view class="param-item" wx:if="{{product.specText && product.specText.length}}">
            <text class="param-label">规　　格</text>
            <text class="param-value">{{product.specText.join(' / ')}}</text>
          </view>
          <view class="param-item" wx:if="{{product.category}}">
            <text class="param-label">分　　类</text>
            <text class="param-value">{{product.category}}</text>
          </view>
          <view class="param-item" wx:if="{{product.stock !== undefined}}">
            <text class="param-label">库　　存</text>
            <text class="param-value">
              <text wx:if="{{product.stock > 0}}">{{product.stock}} 件</text>
              <text wx:else class="out-of-stock">已售罄</text>
            </text>
          </view>
          <view class="param-item" wx:if="{{product.sales_count !== undefined}}">
            <text class="param-label">已　　售</text>
            <text class="param-value">{{product.sales_count}} 件</text>
          </view>
        </view>
      </view>

      <!-- 底部安全占位 -->
      <view class="bottom-safe"></view>
    </scroll-view>

    <!-- 固定底部操作栏 -->
    <view class="bottom-bar">
      <view class="bottom-bar-inner">
        <view class="bottom-price-wrap">
          <text class="bottom-price">¥{{product.price}}</text>
        </view>
        <button class="buy-btn" bindtap="handleBuy">立即购买</button>
      </view>
    </view>
  </block>
</view>
