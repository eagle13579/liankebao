.detail { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }
.cover { width: 100%; height: 760rpx; display: block; }
.info { background: #fff; border-radius: 32rpx 32rpx 0 0; margin-top: -32rpx; padding: 48rpx 40rpx; position: relative; }
.name { font-size: 40rpx; font-weight: 700; color: #1a1a2e; display: block; margin-bottom: 20rpx; line-height: 1.4; }
.price { font-size: 56rpx; font-weight: 800; color: #f59e0b; display: block; margin-bottom: 16rpx; }
.earn { font-size: 24rpx; color: #0ea5e9; background: #f0f9ff; padding: 6rpx 20rpx; border-radius: 8rpx; display: inline-block; margin-bottom: 32rpx; }
.desc { font-size: 28rpx; color: #64748b; line-height: 1.8; display: block; }
.buy-btn { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; line-height: 100rpx; background: linear-gradient(135deg,#0ea5e9,#0284c7); color: #fff; font-size: 32rpx; font-weight: 600; border: none; border-radius: 0; text-align: center; }
.buy-btn:active { opacity: 0.9; }
