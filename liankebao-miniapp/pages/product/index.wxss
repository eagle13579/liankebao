/* ========== 页面容器 ========== */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* ========== 加载 & 空状态 ========== */
.loading-wrap,
.empty-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}
.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ========== 骨架屏 ========== */
.skeleton-wrap {
  background: #f5f5f5;
  min-height: 100vh;
}
.skeleton-swiper {
  width: 100%;
  height: 760rpx;
  background: linear-gradient(90deg, #e2e8f0 25%, #edf2f7 37%, #e2e8f0 63%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.6s ease-in-out infinite;
}
.skeleton-card {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  padding: 48rpx 40rpx 40rpx;
  position: relative;
}
.skeleton-title {
  height: 32rpx;
  width: 70%;
  margin-bottom: 16rpx;
}
.skeleton-title-short {
  width: 45%;
  margin-bottom: 32rpx;
}
.skeleton-price {
  height: 48rpx;
  width: 35%;
  margin-bottom: 32rpx;
}
.skeleton-desc {
  height: 24rpx;
  width: 100%;
  margin-bottom: 16rpx;
}
.skeleton-desc-short {
  width: 60%;
  margin-bottom: 0;
}
.skeleton-params {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
}
.skeleton-param-row {
  height: 28rpx;
  width: 100%;
  margin-bottom: 28rpx;
}
.skeleton-param-row-last {
  width: 55%;
  margin-bottom: 0;
}

/* ========== 可滚动内容区域 ========== */
.scroll-area {
  flex: 1;
  padding-bottom: 120rpx;
}

/* ========== 轮播图 ========== */
.swiper {
  width: 100%;
  height: 760rpx;
}
.swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}
.placeholder-img {
  background: #f1f5f9;
}

/* ========== 基础信息卡片 ========== */
.info-card {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  padding: 48rpx 40rpx 40rpx;
  position: relative;
}
.product-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.product-price {
  font-size: 56rpx;
  font-weight: 800;
  color: #f59e0b;
  display: block;
  margin-bottom: 16rpx;
}
.product-earn {
  font-size: 24rpx;
  color: #0ea5e9;
  background: #f0f9ff;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 32rpx;
}
.product-desc {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.8;
  display: block;
}

/* ========== 参数面板 ========== */
.params-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
}
.params-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 28rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #0ea5e9;
  line-height: 1.2;
}
.params-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.param-item {
  display: flex;
  align-items: baseline;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.param-item:last-child {
  border-bottom: none;
}
.param-label {
  font-size: 26rpx;
  color: #94a3b8;
  width: 120rpx;
  flex-shrink: 0;
}
.param-value {
  font-size: 26rpx;
  color: #334155;
  flex: 1;
}
.out-of-stock {
  color: #ef4444;
  font-weight: 500;
}

/* ========== 底部安全占位 ========== */
.bottom-safe {
  height: 140rpx;
}

/* ========== 固定底部操作栏 ========== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom, 0px);
  padding-bottom: constant(safe-area-inset-bottom, 0px);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
.bottom-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  height: 100rpx;
  box-sizing: border-box;
}
.bottom-price-wrap {
  flex: 1;
}
.bottom-price {
  font-size: 44rpx;
  font-weight: 800;
  color: #f59e0b;
}
.buy-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: 40rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}
.buy-btn::after {
  border: none;
}
.buy-btn:active {
  opacity: 0.9;
}
