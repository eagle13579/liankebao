<!-- pages/brochure-preview/index.wxml -->
<view class="preview-page">
  <!-- 导航 -->
  <view class="preview-nav">
    <view class="nav-back" bindtap="goBackEdit">‹ 返回</view>
    <text class="nav-title">预览画册</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="flipbook-container"
    bindtouchstart="onTouchStart"
    bindtouchend="onTouchEnd">

    <!-- 封面页 -->
    <view class="flip-card {{currentPage === 0 ? 'active' : ''}}">
      <view class="card-inner glass">
        <view class="fp-avatar">
          <text class="fp-avatar-text">{{brochure.name ? brochure.name[0] : '?'}}</text>
        </view>
        <text class="fp-name">{{brochure.name || '未填写'}}</text>
        <text class="fp-company">{{brochure.company}}{{brochure.position ? ' · ' + brochure.position : ''}}</text>
        <text class="fp-bio" wx:if="{{brochure.bio}}">{{brochure.bio}}</text>
        <text class="fp-purpose" wx:if="{{brochure.purpose}}">{{brochure.purpose}}</text>
        <view class="fp-tags">
          <view wx:if="{{brochure.provide_tags && brochure.provide_tags.length > 0}}">
            <text class="tag-label">提供:</text>
            <text class="tag tag-provide" wx:for="{{brochure.provide_tags}}" wx:key="*this">{{item}}</text>
          </view>
          <view wx:if="{{brochure.need_tags && brochure.need_tags.length > 0}}">
            <text class="tag-label">需要:</text>
            <text class="tag tag-need" wx:for="{{brochure.need_tags}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 联系方式页 -->
    <view class="flip-card {{currentPage === 1 ? 'active' : ''}}">
      <view class="card-inner glass">
        <text class="fp-title">📞 联系方式</text>
        <view class="contact-item" wx:if="{{brochure.phone}}">
          <text class="contact-icon">📞</text>
          <text>{{brochure.phone}}</text>
        </view>
        <view class="contact-item" wx:if="{{brochure.email}}">
          <text class="contact-icon">✉️</text>
          <text>{{brochure.email}}</text>
        </view>
        <view class="contact-item" wx:if="{{brochure.wechat}}">
          <text class="contact-icon">💬</text>
          <text>{{brochure.wechat}}</text>
        </view>
      </view>
    </view>

    <!-- 产品图片页 -->
    <view class="flip-card {{currentPage === 2 ? 'active' : ''}}">
      <view class="card-inner glass">
        <text class="fp-title">📸 产品展示</text>
        <view class="fp-images" wx:if="{{brochure.images && brochure.images.length > 0}}">
          <image class="fp-image" wx:for="{{brochure.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
        </view>
        <view class="fp-empty" wx:else>
          <text class="empty-icon">🖼️</text>
          <text>暂无展示图片</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 指示器 -->
  <view class="page-indicator">
    <view class="dot {{currentPage === 0 ? 'active' : ''}}"></view>
    <view class="dot {{currentPage === 1 ? 'active' : ''}}"></view>
    <view class="dot {{currentPage === 2 ? 'active' : ''}}"></view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn-secondary" bindtap="goBackEdit">← 返回编辑</button>
    <button class="btn-primary" bindtap="goPublish">发布画册 →</button>
  </view>
</view>
