/* pages/brochure-preview/index.wxss */
.preview-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  padding-bottom: 160rpx;
}
.preview-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 32rpx 24rpx;
}
.nav-back { font-size: 32rpx; color: #94a3b8; padding: 8rpx; width: 120rpx; }
.nav-title { font-size: 34rpx; font-weight: 600; color: #f1f5f9; }
.nav-placeholder { width: 120rpx; }

.flipbook-container {
  position: relative;
  padding: 0 32rpx;
  min-height: 600rpx;
}
.flip-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  opacity: 0;
  transform: scale(0.92) translateX(40rpx);
  transition: all 0.3s ease;
  pointer-events: none;
}
.flip-card.active {
  opacity: 1;
  transform: scale(1) translateX(0);
  position: relative;
  left: 0;
  right: 0;
  pointer-events: auto;
}
.card-inner {
  padding: 48rpx 36rpx;
  text-align: center;
  min-height: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fp-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.3);
}
.fp-avatar-text { font-size: 52rpx; font-weight: 700; color: #fff; }
.fp-name { font-size: 40rpx; font-weight: 700; color: #f1f5f9; display: block; }
.fp-company { font-size: 24rpx; color: #94a3b8; display: block; margin-bottom: 8rpx; }
.fp-bio { font-size: 24rpx; color: #64748b; display: block; margin: 12rpx 0; }
.fp-purpose { font-size: 22rpx; color: #f5576c; padding: 4rpx 16rpx; background: rgba(245,87,108,0.1); border-radius: 16rpx; }
.fp-tags { margin-top: 16rpx; width: 100%; text-align: left; }
.fp-title { font-size: 32rpx; font-weight: 600; color: #f1f5f9; margin-bottom: 24rpx; display: block; text-align: center; }

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  width: 100%;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  font-size: 28rpx;
  color: #e2e8f0;
}
.contact-icon { font-size: 32rpx; margin-right: 20rpx; width: 48rpx; text-align: center; }

.fp-images { display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; }
.fp-image { width: 200rpx; height: 200rpx; border-radius: 16rpx; }
.fp-empty { text-align: center; padding: 60rpx; color: #64748b; }
.fp-empty text { display: block; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

.page-indicator {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin: 32rpx 0;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.15);
}
.dot.active {
  width: 40rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.bottom-bar {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
}
.bottom-bar button { flex: 1; }
