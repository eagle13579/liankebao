<view class="address-page">
  <view class="header">
    <text>地址管理</text>
  </view>

  <scroll-view class="address-list" scroll-y>
    <block wx:if="{{loading}}">
      <text class="loading">加载中...</text>
    </block>
    <block wx:elif="{{addresses.length === 0}}">
      <view class="empty-state">
        <text class="empty-icon">📍</text>
        <text class="empty-text">暂无地址</text>
      </view>
    </block>
    <block wx:else>
      <view wx:for="{{addresses}}" wx:key="id" class="address-card">
        <view class="card-main">
          <view class="card-header">
            <view class="card-user">
              <text class="card-name">{{item.name}}</text>
              <text class="card-mobile">{{item.mobile}}</text>
            </view>
            <text class="default-badge" wx:if="{{item.is_default}}">默认</text>
          </view>
          <text class="card-address">{{item.address}}</text>
        </view>
        <view class="card-actions">
          <view class="action-btn edit-btn" data-id="{{item.id}}" bindtap="handleEdit">
            <text>编辑</text>
          </view>
          <view class="action-btn delete-btn" data-id="{{item.id}}" bindtap="handleDelete">
            <text>删除</text>
          </view>
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="add-btn-wrapper">
    <button class="add-btn" bindtap="handleAdd">+ 新增地址</button>
  </view>
</view>
