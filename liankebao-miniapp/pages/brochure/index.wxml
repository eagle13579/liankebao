<!-- 画册首页 - 骨架屏（加载中） -->
<block wx:if="{{loading}}">
  <view class="skeleton-page">
    <view class="skeleton-header">
      <view class="skeleton-avatar"></view>
      <view class="skeleton-name"></view>
      <view class="skeleton-desc"></view>
      <view class="skeleton-desc short"></view>
    </view>
    <view class="skeleton-section">
      <view class="skeleton-title"></view>
      <scroll-view class="skeleton-products" scroll-x>
        <view class="skeleton-product" wx:for="{{skeletonItems}}" wx:key="*this"></view>
      </scroll-view>
    </view>
    <view class="skeleton-section">
      <view class="skeleton-title"></view>
      <view class="skeleton-need" wx:for="{{skeletonItems}}" wx:key="*this"></view>
    </view>
  </view>
</block>

<!-- 错误状态 -->
<block wx:elif="{{error}}">
  <view class="error-page">
    <image class="error-icon" src="/images/error.png" mode="aspectFit"></image>
    <text class="error-text">{{errorMsg}}</text>
    <button class="error-btn" bindtap="onRetry">重新加载</button>
  </view>
</block>

<!-- 主内容 -->
<block wx:else>
  <view class="page-brochure">
    <!-- ===== 顶部头像区 ===== -->
    <view class="profile-section">
      <view class="profile-bg"></view>
      <view class="profile-content">
        <view class="avatar-wrapper">
          <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="avatar-ring"></view>
        </view>
        <view class="profile-info">
          <text class="name">{{userInfo.name}}</text>
          <text class="company" wx:if="{{userInfo.company}}">{{userInfo.company}}</text>
          <text class="position" wx:if="{{userInfo.position}}">{{userInfo.position}}</text>
          <text class="bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 信任网络区 ===== -->
    <view class="trust-section">
      <view class="trust-item">
        <text class="trust-count">{{trustCount}}</text>
        <text class="trust-label">信任人数</text>
      </view>
      <view class="trust-divider"></view>
      <view class="trust-item">
        <image wx:if="{{hasBadge}}" class="badge-icon" src="/images/badge.png" mode="aspectFit"></image>
        <text class="badge-label" wx:if="{{!hasBadge}}">未认证</text>
        <text class="badge-label verified" wx:else>已认证</text>
      </view>
    </view>

    <!-- ===== 产品列表（横向滚动） ===== -->
    <view class="section" wx:if="{{products.length > 0}}">
      <view class="section-header">
        <text class="section-title">我的产品</text>
        <text class="section-more" wx:if="{{products.length > 5}}">查看更多 ›</text>
      </view>
      <scroll-view class="product-scroll" scroll-x enable-flex>
        <view
          class="product-card"
          wx:for="{{products}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onProductTap"
        >
          <image class="product-cover" src="{{item.cover || item.image || '/images/default-product.png'}}" mode="aspectFill"></image>
          <view class="product-info">
            <text class="product-name">{{item.name || item.title}}</text>
            <text class="product-price" wx:if="{{item.price}}">{{item.price}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ===== 需求列表 ===== -->
    <view class="section" wx:if="{{needs.length > 0}}">
      <view class="section-header">
        <text class="section-title">我的需求</text>
      </view>
      <view class="need-list">
        <view
          class="need-card"
          wx:for="{{needs}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onNeedTap"
        >
          <view class="need-tag">{{item.category || item.type || '需求'}}</view>
          <view class="need-body">
            <text class="need-title">{{item.title || item.name}}</text>
            <text class="need-desc" wx:if="{{item.description}}">{{item.description}}</text>
          </view>
          <view class="need-status {{item.status}}">
            <text>{{item.status === 'active' ? '进行中' : item.status === 'completed' ? '已完成' : item.status}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 空数据提示 ===== -->
    <view class="empty-section" wx:if="{{!products.length && !needs.length}}">
      <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
      <text class="empty-text">暂无内容</text>
    </view>

    <!-- ===== 分享按钮 ===== -->
    <view class="share-section">
      <button class="share-btn" open-type="share">
        <image class="share-icon" src="/images/share.png" mode="aspectFit"></image>
        <text>分享画册</text>
      </button>
    </view>
  </view>
</block>
