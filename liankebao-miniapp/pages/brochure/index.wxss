/* 链客宝AI数字名片 - 深色毛玻璃风格 */

page {
  background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 30%, #16213e 70%, #0f3460 100%);
  height: 100vh;
  overflow: hidden;
}

.brochure-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100vh;
  padding: 40rpx 20rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 分享栏 ===== */
.share-bar {
  width: 100%;
  display: flex;
  justify-content: flex-end;
  padding: 10rpx 20rpx;
  box-sizing: border-box;
  z-index: 100;
}

.share-btn {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.share-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.share-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 500;
}

/* ===== 画册容器 ===== */
.album-wrapper {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* ===== 卡片基础样式 ===== */
.page-card {
  position: absolute;
  width: 520rpx;
  height: 720rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  box-shadow:
    0 8rpx 40rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  overflow: hidden;
}

/* 卡片毛玻璃高光 */
.page-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
}

/* 三种状态 */
.page-card.active {
  transform: translateX(0) scale(1);
  opacity: 1;
  z-index: 10;
}

.page-card.prev {
  transform: translateX(-120%) scale(0.85) rotateY(-5deg);
  opacity: 0;
  z-index: 1;
}

.page-card.next {
  transform: translateX(120%) scale(0.85) rotateY(5deg);
  opacity: 0;
  z-index: 1;
}

/* ===== 封面页 ===== */
.cover-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(64, 224, 208, 0.4);
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
}

/* 脉冲动画 */
.avatar-pulse {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.cover-avatar::after {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(64, 224, 208, 0.3);
  animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.25); opacity: 0.2; }
  100% { transform: scale(1); opacity: 0.6; }
}

.cover-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.cover-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.cover-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
}

.cover-badge {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* ===== 内容页通用 ===== */
.card-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 36rpx;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 2rpx;
}

/* ===== 产品页 ===== */
.product-list {
  width: 100%;
}

.product-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
}

/* ===== 需求页 ===== */
.demand-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.demand-tag {
  padding: 12rpx 28rpx;
  background: rgba(102, 126, 234, 0.15);
  border: 1rpx solid rgba(102, 126, 234, 0.25);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.contact-hint {
  text-align: center;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.8;
}

.contact-phone {
  font-size: 24rpx;
  color: rgba(64, 224, 208, 0.7);
  font-weight: 600;
}

/* ===== 空状态提示 ===== */
.empty-tip {
  width: 100%;
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ===== 页码指示器 ===== */
.page-indicator {
  display: flex;
  gap: 12rpx;
  margin: 30rpx 0 20rpx;
  z-index: 50;
}

.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 40rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 0 20rpx rgba(102, 126, 234, 0.4);
}

/* ===== 翻页提示 ===== */
.swipe-hint {
  display: flex;
  justify-content: space-between;
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
  z-index: 50;
}

.hint-arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.hint-arrow.left {
  text-align: left;
}

.hint-arrow.right {
  text-align: right;
}

/* ===== 免费创建名片按钮 ===== */
.create-card-btn {
  width: 520rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  margin: 20rpx auto 10rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.3);
  z-index: 50;
  position: relative;
}

.create-card-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
