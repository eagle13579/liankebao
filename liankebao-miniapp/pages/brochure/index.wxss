/* ============================================================ */
/*  画册首页 pages/brochure/index                                */
/*  主题色: #0ea5e9 (深蓝)                                      */
/* ============================================================ */

/* ---------- 全局 ---------- */
.page-brochure {
  min-height: 100vh;
  background: linear-gradient(180deg, #0ea5e9 0%, #0284c7 35%, #f5f5f5 35%);
  padding-bottom: 120rpx;
}

/* ============================================================ */
/*  骨架屏                                                      */
/* ============================================================ */
.skeleton-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 30rpx;
}

.skeleton-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

.skeleton-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 24rpx;
}

.skeleton-name {
  width: 200rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 16rpx;
}

.skeleton-desc {
  width: 300rpx;
  height: 28rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 12rpx;
}

.skeleton-desc.short {
  width: 200rpx;
}

.skeleton-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.skeleton-title {
  width: 160rpx;
  height: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 24rpx;
}

.skeleton-products {
  display: flex;
  white-space: nowrap;
}

.skeleton-product {
  display: inline-block;
  width: 200rpx;
  height: 280rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.skeleton-need {
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 16rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ============================================================ */
/*  错误页                                                      */
/* ============================================================ */
.error-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f5f5f5;
  padding: 60rpx;
}

.error-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.error-btn {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #0ea5e9;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  text-align: center;
}

/* ============================================================ */
/*  顶部头像区                                                  */
/* ============================================================ */
.profile-section {
  position: relative;
  padding: 0 30rpx;
  padding-top: 20rpx;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 30rpx;
  right: 30rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  border-radius: 24rpx 24rpx 0 0;
}

.profile-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 40rpx 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(14, 165, 233, 0.15);
}

.avatar-wrapper {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  margin-top: -60rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  background: #f0f0f0;
}

.avatar-ring {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(14, 165, 233, 0.3);
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.company {
  font-size: 28rpx;
  color: #0ea5e9;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.position {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.bio {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  text-align: center;
  margin-top: 12rpx;
  padding: 0 20rpx;
}

/* ============================================================ */
/*  信任网络区                                                  */
/* ============================================================ */
.trust-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.trust-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trust-count {
  font-size: 44rpx;
  font-weight: 700;
  color: #0ea5e9;
}

.trust-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.trust-divider {
  width: 2rpx;
  height: 60rpx;
  background: #eee;
  margin: 0 20rpx;
}

.badge-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.badge-label {
  font-size: 24rpx;
  color: #999;
}

.badge-label.verified {
  color: #0ea5e9;
  font-weight: 500;
}

/* ============================================================ */
/*  区块通用                                                    */
/* ============================================================ */
.section {
  margin: 0 30rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-more {
  font-size: 26rpx;
  color: #0ea5e9;
}

/* ============================================================ */
/*  产品列表（横向滚动）                                        */
/* ============================================================ */
.product-scroll {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.product-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #fafafa;
  border-radius: 16rpx;
  overflow: hidden;
  transition: transform 0.2s;
}

.product-card:active {
  transform: scale(0.97);
}

.product-cover {
  width: 240rpx;
  height: 240rpx;
  background: #f0f0f0;
}

.product-info {
  padding: 16rpx 14rpx;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}

.product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #f59e0b;
}

/* ============================================================ */
/*  需求列表                                                    */
/* ============================================================ */
.need-list {
  display: flex;
  flex-direction: column;
}

.need-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.need-card:last-child {
  border-bottom: none;
}

.need-card:active {
  background: #fafafa;
  margin: 0 -30rpx;
  padding-left: 30rpx;
  padding-right: 30rpx;
  border-radius: 16rpx;
}

.need-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #0ea5e9;
  background: rgba(14, 165, 233, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.need-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.need-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.need-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.need-status {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
  background: #f5f5f5;
  color: #999;
}

.need-status.active {
  background: rgba(14, 165, 233, 0.1);
  color: #0ea5e9;
}

.need-status.completed {
  background: rgba(34, 197, 94, 0.1);
  color: #22c55e;
}

/* ============================================================ */
/*  空数据提示                                                  */
/* ============================================================ */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* ============================================================ */
/*  分享按钮                                                    */
/* ============================================================ */
.share-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  padding: 0;
}

.share-btn::after {
  border: none;
}

.share-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}
