.pool { min-height: 100vh; background: #f5f5f5; padding-bottom: 120rpx; }

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 48rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #1a1a2e; }
.search-clear { font-size: 28rpx; color: #94a3b8; padding: 8rpx; }

/* 分类 */
.categories {
  display: flex;
  white-space: nowrap;
  padding: 12rpx 24rpx;
  margin-bottom: 8rpx;
}
.category {
  display: inline-flex;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #64748b;
  background: #fff;
  border-radius: 36rpx;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.category.active {
  color: #fff;
  background: linear-gradient(135deg, #0ea5e9, #0284c7);
  font-weight: 600;
}

/* 网格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 12rpx;
}
.grid-item {
  width: 50%;
  box-sizing: border-box;
  padding: 12rpx;
}
.grid-item > view {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.grid-item:active { opacity: 0.9; }
.grid-img {
  width: 100%;
  height: 300rpx;
  display: block;
}
.grid-body {
  padding: 16rpx 20rpx 20rpx;
}
.grid-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}
.grid-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #f59e0b;
  display: block;
}
.grid-earn {
  font-size: 20rpx;
  color: #0ea5e9;
  background: #f0f9ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 8rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
}
.load-more-btn {
  font-size: 26rpx;
  color: #0ea5e9;
  padding: 12rpx 48rpx;
  border: 1px solid #0ea5e9;
  border-radius: 36rpx;
}
.load-more-btn:active { opacity: 0.7; }
.load-more-done {
  font-size: 24rpx;
  color: #94a3b8;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

/* ===== 骨架屏 ===== */
@keyframes skeleton-shimmer {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

.skeleton {
  padding: 0 12rpx;
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
}

.skeleton-item {
  width: 50%;
  box-sizing: border-box;
  padding: 12rpx;
}

.skeleton-item > view {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.skeleton-img {
  width: 100%;
  height: 300rpx;
  background: #e2e8f0;
  display: block;
}

.skeleton-body {
  padding: 16rpx 20rpx 20rpx;
}

.skeleton-line {
  height: 24rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-line-70 { width: 70%; }
.skeleton-line-40 { width: 40%; }
.skeleton-line-25 { width: 25%; }
