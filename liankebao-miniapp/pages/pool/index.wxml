<view class="pool">
  <!-- 搜索框 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索产品..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
    <text class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="categories" scroll-x enable-flex>
    <view class="category {{currentCategory === '' ? 'active' : ''}}" data-cat="" bindtap="selectCategory">全部</view>
    <view class="category {{currentCategory === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" data-cat="{{item}}" bindtap="selectCategory">{{item}}</view>
  </scroll-view>

  <!-- 产品网格 -->
  <block wx:if="{{loading && products.length === 0}}">
    <view class="loading">加载中...</view>
  </block>

  <!-- 空状态：搜索无结果 / 暂无产品 -->
  <block wx:elif="{{products.length === 0 && !loading}}">
    <view wx:if="{{keyword}}" class="empty-state">
      <text class="empty-state-icon">🔎</text>
      <text class="empty-state-title">未找到产品</text>
      <text class="empty-state-desc">试试其他关键词或分类</text>
    </view>
    <view wx:else class="empty-state">
      <text class="empty-state-icon">📦</text>
      <text class="empty-state-title">暂无产品</text>
      <text class="empty-state-desc">产品池为空，请稍后再来看看</text>
    </view>
  </block>

  <!-- 产品列表 -->
  <block wx:else>
    <view class="grid">
      <view class="grid-item" wx:for="{{products}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
        <image class="grid-img" src="{{item.firstImage}}" mode="aspectFill" />
        <view class="grid-body">
          <text class="grid-name">{{item.name}}</text>
          <text class="grid-price">¥{{item.price}}</text>
          <text class="grid-earn" wx:if="{{item.earn_per_share > 0}}">赚 ¥{{item.earn_per_share}}</text>
        </view>
      </view>
    </view>
    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text class="load-more-btn" bindtap="loadMore">加载更多</text>
    </view>
    <view class="load-more" wx:elif="{{products.length > 0}}">
      <text class="load-more-done">— 已加载全部 —</text>
    </view>
  </block>
</view>
