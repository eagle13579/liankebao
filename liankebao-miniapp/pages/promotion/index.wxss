.promotion { min-height: 100vh; background: #f5f5f5; }
.header { padding: 60rpx 40rpx 40rpx; background: linear-gradient(135deg,#0ea5e9,#0284c7); text-align: center; }
.header text { font-size: 36rpx; font-weight: 700; color: #fff; }

.tabs { display: flex; background: #fff; padding: 0 20rpx; border-bottom: 1px solid #f1f5f9; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 26rpx; color: #64748b; position: relative; }
.tab-item.active { color: #0ea5e9; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 4rpx; background: #0ea5e9; border-radius: 2rpx; }

.content { padding: 32rpx; }

/* 统计卡片 */
.stats-section { display: flex; gap: 20rpx; margin-bottom: 32rpx; }
.stat-card { flex: 1; background: #fff; border-radius: 20rpx; padding: 28rpx 20rpx; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.stat-label { font-size: 22rpx; color: #94a3b8; display: block; margin-bottom: 12rpx; }
.stat-value { font-size: 36rpx; font-weight: 700; color: #1a1a2e; display: block; }
.stat-value.primary { color: #0ea5e9; }
.stat-value.success { color: #10b981; }

.withdraw-btn { width: 100%; height: 92rpx; line-height: 92rpx; background: linear-gradient(135deg,#0ea5e9,#0284c7); color: #fff; font-size: 30rpx; font-weight: 600; border-radius: 24rpx; border: none; margin-bottom: 32rpx; }
.withdraw-btn:active { opacity: 0.9; }

.info-card { background: #fff; border-radius: 20rpx; padding: 32rpx; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.info-title { font-size: 28rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 16rpx; }
.info-text { font-size: 24rpx; color: #64748b; line-height: 1.6; }

/* 产品卡片 */
.product-card { background: #fff; border-radius: 20rpx; margin-bottom: 20rpx; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.product-body { display: flex; padding: 32rpx; }
.product-thumb { width: 160rpx; height: 160rpx; border-radius: 16rpx; margin-right: 24rpx; }
.product-thumb-placeholder { width: 160rpx; height: 160rpx; border-radius: 16rpx; margin-right: 24rpx; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.product-name { font-size: 28rpx; font-weight: 600; color: #1a1a2e; display: block; margin-bottom: 8rpx; }
.product-price { font-size: 32rpx; font-weight: 700; color: #0ea5e9; display: block; margin-bottom: 8rpx; }
.product-earn { font-size: 24rpx; color: #10b981; display: inline-block; background: #ecfdf5; padding: 2rpx 16rpx; border-radius: 16rpx; }
.product-actions { padding: 20rpx 32rpx; border-top: 1px solid #f1f5f9; text-align: right; }
.share-btn { font-size: 24rpx; color: #fff; background: linear-gradient(135deg,#0ea5e9,#0284c7); padding: 10rpx 32rpx; border-radius: 24rpx; }
.share-btn:active { opacity: 0.8; }

/* 提现记录 */
.withdraw-card { background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.withdraw-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.withdraw-amount { font-size: 32rpx; font-weight: 700; color: #1a1a2e; }
.withdraw-status { font-size: 24rpx; padding: 4rpx 20rpx; border-radius: 20rpx; }
.status-pending { color: #f59e0b; background: #fffbeb; }
.status-success { color: #10b981; background: #ecfdf5; }
.withdraw-time { font-size: 22rpx; color: #94a3b8; }
