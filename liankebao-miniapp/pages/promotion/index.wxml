<view class="promotion">
  <view class="header">
    <text>推广中心</text>
  </view>

  <view class="tabs">
    <view class="tab-item {{tabActive === 'stats' ? 'active' : ''}}" data-tab="stats" bindtap="switchTab">
      <text>收益概览</text>
    </view>
    <view class="tab-item {{tabActive === 'products' ? 'active' : ''}}" data-tab="products" bindtap="switchTab">
      <text>推广产品</text>
    </view>
    <view class="tab-item {{tabActive === 'withdrawals' ? 'active' : ''}}" data-tab="withdrawals" bindtap="switchTab">
      <text>提现记录</text>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <block wx:if="{{loading}}">
      <text class="loading">加载中...</text>
    </block>

    <!-- 收益概览 -->
    <block wx:elif="{{tabActive === 'stats'}}">
      <view class="stats-section">
        <view class="stat-card">
          <text class="stat-label">累计收益</text>
          <text class="stat-value primary">¥{{stats.total_earnings || '0.00'}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">可提现</text>
          <text class="stat-value success">¥{{stats.balance || '0.00'}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">已提现</text>
          <text class="stat-value">¥{{stats.withdrawn || '0.00'}}</text>
        </view>
      </view>
      <button class="withdraw-btn" bindtap="goWithdraw">申请提现</button>

      <view class="info-card">
        <text class="info-title">推广说明</text>
        <text class="info-text">每成功推广一笔订单，您将获得对应产品的推广佣金。佣金将在订单完成后结算到可提现余额。</text>
      </view>
    </block>

    <!-- 可推广产品 -->
    <block wx:elif="{{tabActive === 'products'}}">
      <block wx:if="{{products.length === 0}}">
        <view class="empty-state">
          <text class="empty-state-icon">📢</text>
          <text class="empty-state-title">暂无推广产品</text>
          <text class="empty-state-desc">可推广的产品会在这里展示</text>
        </view>
      </block>
      <block wx:else>
        <view wx:for="{{products}}" wx:key="id" class="product-card">
          <view class="product-body" data-id="{{item.id}}" bindtap="goProduct">
            <image class="product-thumb" src="{{item.firstImage}}" mode="aspectFill" wx:if="{{item.firstImage}}"></image>
            <view class="product-thumb-placeholder" wx:else>
              <text>📦</text>
            </view>
            <view class="product-info">
              <text class="product-name">{{item.name}}</text>
              <text class="product-price">¥{{item.price}}</text>
              <text class="product-earn" wx:if="{{item.earn_per_share > 0}}">推广赚 ¥{{item.earn_per_share}}</text>
            </view>
          </view>
          <view class="product-actions">
            <text class="share-btn" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="shareProduct">分享推广</text>
          </view>
        </view>
      </block>
    </block>

    <!-- 提现记录 -->
    <block wx:elif="{{tabActive === 'withdrawals'}}">
      <block wx:if="{{withdrawals.length === 0}}">
        <view class="empty-state">
          <text class="empty-state-icon">💳</text>
          <text class="empty-state-title">暂无提现记录</text>
          <text class="empty-state-desc">提现申请通过后会显示在这里</text>
        </view>
      </block>
      <block wx:else>
        <view wx:for="{{withdrawals}}" wx:key="id" class="withdraw-card">
          <view class="withdraw-top">
            <text class="withdraw-amount">¥{{item.amount}}</text>
            <text class="withdraw-status status-{{item.status}}">{{item.status === 'pending' ? '处理中' : item.status === 'success' ? '已到账' : '已驳回'}}</text>
          </view>
          <text class="withdraw-time">{{item.created_at}}</text>
        </view>
      </block>
    </block>
  </scroll-view>
</view>
