.login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  padding: 0 40rpx;
  box-sizing: border-box;
}

/* Brand */
.brand {
  text-align: center;
  margin-bottom: 80rpx;
}
.brand .logo {
  font-size: 72rpx;
  font-weight: 700;
  color: #0ea5e9;
}
.brand .desc {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
  display: block;
}

/* WeChat Login */
.wechat-btn {
  background: #07c160;
  color: #fff;
  width: 600rpx;
  height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
  line-height: 96rpx;
}
.wechat-btn::after {
  border: none;
}

/* Account Login Form */
.form {
  width: 600rpx;
}
.input-group {
  margin-bottom: 32rpx;
}
.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.input-field {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid #e0e0e0;
  transition: border-color 0.2s;
}
.input-field:focus {
  border-color: #0ea5e9;
}
.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #0ea5e9, #0c8ed6);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  line-height: 88rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.3);
}
.login-btn::after {
  border: none;
}
.login-btn:active {
  opacity: 0.85;
}

/* Links */
.switch-link {
  color: #0ea5e9;
  font-size: 26rpx;
  margin-top: 36rpx;
  padding: 12rpx 24rpx;
}
.switch-link:active {
  opacity: 0.65;
}
.register-link {
  color: #999;
  font-size: 26rpx;
  margin-top: 16rpx;
  padding: 12rpx 24rpx;
}
.register-link:active {
  opacity: 0.65;
}
