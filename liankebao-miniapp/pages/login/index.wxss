.login { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f5f5f5; }
.brand { text-align: center; margin-bottom: 80rpx; }
.brand .logo { font-size: 72rpx; font-weight: 700; color: #0ea5e9; }
.brand .desc { font-size: 28rpx; color: #666; margin-top: 16rpx; display: block; }
.wechat-btn { background: #07c160; color: #fff; width: 600rpx; border-radius: 48rpx; }
.wechat-btn::after { border: none; }
