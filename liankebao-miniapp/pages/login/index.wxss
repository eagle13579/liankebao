/* pages/login/index.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* Brand */
.login-brand {
  text-align: center;
  margin-bottom: 20rpx;
}
.brand-icon {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}
.brand-title {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}
.brand-subtitle {
  font-size: 28rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  display: block;
}

/* Slogan */
.brand-slogan {
  margin: 48rpx 0 80rpx;
  text-align: center;
}
.slogan-text {
  font-size: 30rpx;
  color: #64748b;
  font-style: italic;
  letter-spacing: 2rpx;
}

/* Buttons */
.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.wechat-login-btn {
  width: 100%;
  height: 100rpx;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.35);
}
.wechat-login-btn::after { border: none; }
.wechat-login-btn:active { opacity: 0.9; transform: scale(0.98); }
.wechat-icon { font-size: 36rpx; }

.phone-login-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255,255,255,0.08);
  color: #f1f5f9;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.phone-login-btn::after { border: none; }
.phone-login-btn:active { background: rgba(255,255,255,0.15); }

/* Agreement */
.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  font-size: 24rpx;
  flex-wrap: wrap;
}
.agree-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  border: 2rpx solid #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  margin-right: 8rpx;
  color: transparent;
}
.agree-check.checked {
  background: #667eea;
  border-color: #667eea;
  color: #fff;
}
.agree-text { color: #64748b; margin-right: 4rpx; }
.agree-link { color: #667eea; margin-right: 4rpx; }

/* Footer */
.login-footer {
  position: fixed;
  bottom: 40rpx;
  font-size: 22rpx;
  color: #475569;
}

/* Phone form */
.phone-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding: 100rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #0f0c29 0%, transparent 100%);
}
.phone-back {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 12rpx 0;
}
.phone-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f1f5f9;
  display: block;
  margin-top: 16rpx;
}
.phone-form {
  width: 100%;
  margin-top: 240rpx;
}
.phone-input-group {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}
.phone-prefix {
  font-size: 30rpx;
  color: #94a3b8;
  margin-right: 16rpx;
  padding-right: 16rpx;
  border-right: 1px solid rgba(255,255,255,0.1);
}
.phone-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #f1f5f9;
  background: transparent;
}
.code-input-group {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}
.code-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #f1f5f9;
  background: transparent;
}
.code-timer {
  font-size: 28rpx;
  color: #64748b;
  min-width: 80rpx;
  text-align: right;
}
.send-code-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255,255,255,0.08);
  color: #667eea;
  border: 1px solid rgba(102,126,234,0.3);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}
.send-code-btn::after { border: none; }
.login-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.35);
}
.login-submit-btn::after { border: none; }
.login-submit-btn:active { transform: scale(0.98); }
