<!-- pages/login/index.wxml -->
<view class="login-page">
  <!-- 主界面：微信一键登录 -->
  <block wx:if="{{mode === 'main'}}">
    <view class="login-brand">
      <view class="brand-icon">✨</view>
      <text class="brand-title">AI数字名片</text>
      <text class="brand-subtitle">链客宝·企业家智能商务厅</text>
    </view>

    <view class="brand-slogan">
      <text class="slogan-text">用AI连接每一个商业机会</text>
    </view>

    <view class="login-actions">
      <button class="wechat-login-btn" bindtap="handleWechatLogin" disabled="{{loading}}">
        <text class="wechat-icon">💬</text>
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </button>

      <button class="phone-login-btn" bindtap="switchToPhone">
        📱 手机号登录/注册
      </button>
    </view>

    <view class="agreement">
      <text class="agree-check {{agreePolicy ? 'checked' : ''}}" bindtap="toggleAgree">{{agreePolicy ? '✓' : '○'}}</text>
      <text class="agree-text">登录即表示同意</text>
      <text class="agree-link" data-type="user" bindtap="viewPolicy">《用户协议》</text>
      <text class="agree-text">和</text>
      <text class="agree-link" data-type="privacy" bindtap="viewPolicy">《隐私政策》</text>
    </view>

    <view class="login-footer">
      <text>© 链客宝 提供技术支持</text>
    </view>
  </block>

  <!-- 手机号登录界面 -->
  <block wx:else>
    <view class="phone-header">
      <view class="phone-back" bindtap="backToMain">‹ 返回</view>
      <text class="phone-title">手机号登录</text>
    </view>

    <view class="phone-form">
      <view class="phone-input-group">
        <text class="phone-prefix">+86</text>
        <input class="phone-input" type="number" placeholder="请输入手机号" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
      </view>

      <view class="code-input-group" wx:if="{{codeSent}}">
        <input class="code-input" type="number" placeholder="请输入验证码" maxlength="6" value="{{code}}" bindinput="onCodeInput" />
        <text class="code-timer" wx:if="{{countdown > 0}}">{{countdown}}s</text>
      </view>

      <button class="send-code-btn" wx:if="{{!codeSent}}" bindtap="sendCode" disabled="{{loading}}">
        {{loading ? '发送中...' : '获取验证码'}}
      </button>

      <button class="login-submit-btn" wx:if="{{codeSent}}" bindtap="handlePhoneLogin" disabled="{{loading}}">
        {{loading ? '登录中...' : '登 录'}}
      </button>
    </view>
  </block>
</view>
