/* 链客宝 AI数字名片 全局样式 v3.0 */
/* 深空渐变主题 */

/* CSS 变量 */
page {
  --primary-start: #667eea;
  --primary-end: #764ba2;
  --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
  --primary-light: rgba(102, 126, 234, 0.15);
  --accent: #f5576c;
  --bg-dark-1: #0f0c29;
  --bg-dark-2: #302b63;
  --bg-dark-3: #24243e;
  --bg-gradient: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-tertiary: #64748b;
  --glass-bg: rgba(255, 255, 255, 0.08);
  --glass-border: rgba(255, 255, 255, 0.12);
  --safe-area-top: env(safe-area-inset-top, 0px);
  --safe-area-bottom: env(safe-area-inset-bottom, 0px);
  --safe-area-left: env(safe-area-inset-left, 0px);
  --safe-area-right: env(safe-area-inset-right, 0px);
  background: var(--bg-gradient);
  background-attachment: fixed;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  min-height: 100vh;
}

/* 容器 */
.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* Safe area */
.safe-bottom {
  padding-bottom: calc(constant(safe-area-inset-bottom, 0px));
  padding-bottom: env(safe-area-inset-bottom, 0px);
}

/* 毛玻璃容器 */
.glass {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: 24rpx;
}

/* 主按钮 */
.btn-primary {
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.35);
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
.btn-primary.disabled { opacity: 0.5; pointer-events: none; }

/* 次要按钮 */
.btn-secondary {
  background: var(--glass-bg);
  color: var(--text-primary);
  border: 1px solid var(--glass-border);
  border-radius: 48rpx;
  padding: 28rpx 64rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  backdrop-filter: blur(8px);
}
.btn-secondary::after { border: none; }
.btn-secondary:active { background: rgba(255,255,255,0.15); }

/* 输入框 */
.input-field {
  width: 100%;
  height: 88rpx;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  backdrop-filter: blur(4px);
}
.input-field:focus {
  border-color: var(--primary-start);
  box-shadow: 0 0 0 2rpx var(--primary-light);
}
.input-field::placeholder {
  color: var(--text-tertiary);
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}
.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}
.empty-state-title {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-bottom: 12rpx;
}
.empty-state-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 32rpx;
}

/* 骨架屏 */
@keyframes skeleton-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.06) 25%, rgba(255,255,255,0.12) 37%, rgba(255,255,255,0.06) 63%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.6s ease-in-out infinite;
  border-radius: 8rpx;
}

/* 自定义导航栏占位 */
.nav-placeholder {
  height: calc(88rpx + var(--safe-area-top));
}

/* Toast 覆盖 */
.wx-toast { z-index: 9999; }

/* 页面过渡 */
.fade-in {
  animation: fadeIn 0.3s ease-out;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Tags 样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  background: var(--primary-light);
  color: var(--primary-start);
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* Badge */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #f5576c, #ff6b6b);
  color: #fff;
}
