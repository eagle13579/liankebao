/* 链客宝微信小程序全局样式 */

/* ========== CSS 变量 ========== */
page {
  --safe-area-top: env(safe-area-inset-top, 0px);
  --safe-area-bottom: env(safe-area-inset-bottom, 0px);
  --safe-area-left: env(safe-area-inset-left, 0px);
  --safe-area-right: env(safe-area-inset-right, 0px);
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #1a1a2e;
}

.container {
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}

/* ========== 空状态统一样式 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}
.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}
.empty-state-title {
  font-size: 30rpx;
  color: #64748b;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.empty-state-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ========== 骨架屏动画 ========== */
@keyframes skeleton-shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

.skeleton {
  background: linear-gradient(90deg, #f1f5f9 25%, #e8edf4 37%, #f1f5f9 63%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.6s ease-in-out infinite;
  border-radius: 8rpx;
}

.skeleton-block {
  display: block;
  background: linear-gradient(90deg, #f1f5f9 25%, #e8edf4 37%, #f1f5f9 63%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.6s ease-in-out infinite;
  border-radius: 8rpx;
}

/* ========== 通用 SafeArea 工具类 ========== */
.safe-area-bottom {
  padding-bottom: calc(constant(safe-area-inset-bottom, 0px));
  padding-bottom: env(safe-area-inset-bottom, 0px);
}

/* ========== Primary button style ========== */
.btn-primary {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.9;
}

/* ========== Card style ========== */
.card-shadow {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
