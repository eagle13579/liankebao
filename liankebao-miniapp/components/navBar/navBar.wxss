/* components/navBar/navBar.wxss */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: rgba(15, 12, 41, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.nav-bar.transparent {
  background: transparent;
  border-bottom: none;
}
.nav-content {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}
.nav-left {
  width: 160rpx;
  display: flex;
  align-items: center;
}
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.1);
}
.back-icon {
  font-size: 48rpx;
  color: #fff;
  line-height: 1;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #f1f5f9;
}
.nav-right {
  width: 160rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.nav-share {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.1);
}
.share-icon {
  font-size: 32rpx;
}
