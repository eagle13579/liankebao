<!-- components/navBar/navBar.wxml -->
<view class="nav-bar {{bgTransparent ? 'transparent' : ''}}">
  <view class="nav-placeholder" style="height: {{statusBarHeight}}px;"></view>
  <view class="nav-content" style="height: {{navBarHeight - statusBarHeight}}px;">
    <view class="nav-left">
      <view class="nav-back" wx:if="{{showBack}}" bindtap="onBack">
        <text class="back-icon">‹</text>
      </view>
    </view>
    <view class="nav-title">{{title}}</view>
    <view class="nav-right">
      <view class="nav-share" wx:if="{{showShare}}" bindtap="onShare">
        <text class="share-icon">📤</text>
      </view>
    </view>
  </view>
</view>
