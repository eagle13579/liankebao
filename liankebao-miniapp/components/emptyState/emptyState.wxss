.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-title { font-size: 30rpx; color: #94a3b8; font-weight: 500; margin-bottom: 12rpx; }
.empty-desc { font-size: 24rpx; color: #64748b; margin-bottom: 32rpx; }
.empty-btn { margin-top: 16rpx; }
